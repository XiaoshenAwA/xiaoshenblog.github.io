{
  "name": "my-blog",
  "version": "2.0.0",
  "description": "个人博客系统 - Vite + Supabase",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "start": "npx vite build && node app.js",
    "dev": "node app.js",
    "vite:build": "npx vite build",
    "build:static": "node build.js",
    "build": "npx vite build && node build.js",
    "deploy": "npx vite build && node build.js && npx gh-pages -d dist"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@shikijs/markdown-it": "^4.3.1",
    "@shikijs/transformers": "^4.3.1",
    "@supabase/supabase-js": "^2.49.4",
    "dompurify": "^3.4.12",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "highlight.js": "^11.11.1",
    "js-yaml": "^5.2.1",
    "jsdom": "^29.1.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.3.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-ins-del": "^0.1.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-math": "^6.0.0",
    "method-override": "^3.0.0",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "vite": "^7.0.0"
  }
