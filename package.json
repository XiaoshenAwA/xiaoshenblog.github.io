{
  "name": "my-blog",
  "version": "1.0.0",
  "description": "个人博客系统 - 支持本地编辑与 GitHub Pages 部署",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "build": "(set BASE_PATH=/xiaoshenblog.github.io) && node build.js",
    "deploy": "(set BASE_PATH=/xiaoshenblog.github.io) && node build.js && npx gh-pages -d dist"
  },
  "dependencies": {
    "@shikijs/markdown-it": "^4.3.1",
    "@shikijs/transformers": "^4.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "katex": "^0.17.0",
    "markdown-it": "^14.3.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-ins-del": "^0.1.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-math": "^6.0.0",
    "method-override": "^3.0.0",
    "shiki": "^4.3.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
