<%- include('partials/header', { title: locale.admin?.edit_post_title || '编辑文章' }) %>

  <div class="main-layout single-layout">
    <div class="main-content">
      <div class="form-page reveal">
        <h1 class="form-page-title"><i class="fas fa-edit"></i> <%= locale.admin?.edit_post_title || '编辑文章' %></h1>
        <form action="<%= basePath %>/posts/<%= post.id %>?_method=PUT" method="POST" class="blog-form">
          <div class="form-group">
            <label><i class="fas fa-heading"></i> <%= locale.admin?.new_post_placeholder || '标题' %></label>
            <input type="text" name="title" value="<%= post.title %>" required>
          </div>
          <div class="form-group">
            <label><i class="fas fa-folder"></i> <%= locale.categories?.title || '分类' %></label>
            <input type="text" name="category" value="<%= post.category %>" placeholder="<%= locale.admin?.category_placeholder || '如: 技术, 生活' %>" list="categoryList">
            <datalist id="categoryList">
              <% (allCategories || []).forEach(c => { %>
                <option value="<%= c.name %>">
              <% }) %>
            </datalist>
          </div>
          <div class="form-group">
            <label><i class="fas fa-tags"></i> <%= locale.admin?.tags_placeholder || '标签（逗号分隔）' %></label>
            <input type="text" name="tags" value="<%= post.tagsStr %>" placeholder="<%= locale.admin?.tags_placeholder || '如: JavaScript, Node.js, 生活' %>">
          </div>
          <div class="form-group">
            <label><i class="fas fa-image"></i> <%= locale.admin?.cover_placeholder || '封面图链接（可选）' %></label>
            <input type="text" name="cover" value="<%= post.cover %>" placeholder="<%= locale.admin?.cover_url_placeholder || 'https://example.com/image.jpg' %>">
          </div>
          <div class="form-group">
            <label><i class="fas fa-pen"></i> <%= locale.admin?.content_placeholder || '内容' %></label>
            <textarea name="content" rows="18" required><%= post.content %></textarea>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> <%= locale.admin?.save_button || '保存' %></button>
            <a href="<%= basePath %>/posts/<%= post.id %>" class="btn btn-outline"><i class="fas fa-times"></i> <%= locale.admin?.cancel_button || '取消' %></a>
          </div>
        </form>
      </div>
    </div>
  </div>
<%- include('partials/footer') %>
