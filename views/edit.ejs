<%- include('partials/header', { title: '编辑文章' }) %>

  <div class="main-layout single-layout">
    <div class="main-content">
      <div class="form-page reveal">
        <h1 class="form-page-title"><i class="fas fa-edit"></i> 编辑文章</h1>
        <form action="<%= basePath %>/posts/<%= post.id %>?_method=PUT" method="POST" class="blog-form">
          <div class="form-group">
            <label><i class="fas fa-heading"></i> 标题</label>
            <input type="text" name="title" value="<%= post.title %>" required>
          </div>
          <div class="form-group">
            <label><i class="fas fa-tags"></i> 标签（逗号分隔）</label>
            <input type="text" name="tags" value="<%= post.tagsStr %>" placeholder="如: JavaScript, Node.js, 生活">
          </div>
          <div class="form-group">
            <label><i class="fas fa-image"></i> 封面图链接（可选）</label>
            <input type="text" name="cover" value="<%= post.cover %>" placeholder="https://example.com/image.jpg">
          </div>
          <div class="form-group">
            <label><i class="fas fa-pen"></i> 内容</label>
            <textarea name="content" rows="18" required><%= post.content %></textarea>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> 保存</button>
            <a href="<%= basePath %>/posts/<%= post.id %>" class="btn btn-outline"><i class="fas fa-times"></i> 取消</a>
          </div>
        </form>
      </div>
    </div>
  </div>
<%- include('partials/footer') %>
