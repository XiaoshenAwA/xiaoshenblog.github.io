<%- include('partials/header', { title: '关于' }) %>

  <div class="main-layout single-layout">
    <div class="main-content">
      <div class="about-page reveal">
        <div class="about-hero">
          <div class="about-avatar"><i class="fas fa-user-astronaut"></i></div>
          <h1>关于我</h1>
          <p class="about-tagline"><%= config.ABOUT_TAGLINE %></p>
        </div>

        <div class="about-content card">
          <h3><i class="fas fa-info-circle"></i> 关于本站</h3>
          <div class="post-content">
            <%- aboutHtml %>
          </div>
        </div>

        <div class="about-content card" style="margin-top:24px">
          <h3><i class="fas fa-tags"></i> 所有标签</h3>
          <div class="tag-cloud about-tags">
            <% if (allTags.length > 0) { %>
              <% allTags.forEach(t => { %>
                <% var tagEnc = encodeURIComponent(t) %>
                <a href="<%= basePath %><%= isStatic ? '/tag/' + tagEnc + '/' : '/?tag=' + tagEnc %>" class="cloud-tag"><%= t %></a>
              <% }) %>
            <% } else { %>
              <p class="muted">暂无标签</p>
            <% } %>
          </div>
        </div>

        <div class="about-content card" style="margin-top:24px">
          <h3><i class="fas fa-link"></i> 联系方式</h3>
          <div class="contact-links">
            <a href="<%= config.SOCIAL_GITHUB %>" class="contact-btn"><i class="fab fa-github"></i> GitHub</a>
            <a href="<%= config.SOCIAL_WEIBO %>" class="contact-btn"><i class="fab fa-weibo"></i> 微博</a>
            <a href="<%= config.SOCIAL_TWITTER %>" class="contact-btn"><i class="fab fa-twitter"></i> Twitter</a>
            <a href="<%= config.SOCIAL_EMAIL %>" class="contact-btn"><i class="fas fa-envelope"></i> Email</a>
          </div>
        </div>
      </div>
    </div>
  </div>
<%- include('partials/footer') %>
