<!DOCTYPE html>
<html lang="<%= config.SITE_LANGUAGE %>" data-theme="<%= config.THEME_DEFAULT %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title + ' | ' : '' %><%= config.BLOG_NAME %></title>
  <% if (config.FAVICON) { %>
  <link rel="icon" href="<%= basePath %><%= config.FAVICON %>">
  <% } %>
  <% if (config.PWA_FAVICON_32) { %><link rel="icon" type="image/png" sizes="32x32" href="<%= basePath %><%= config.PWA_FAVICON_32 %>"><% } %>
  <% if (config.PWA_FAVICON_16) { %><link rel="icon" type="image/png" sizes="16x16" href="<%= basePath %><%= config.PWA_FAVICON_16 %>"><% } %>
  <% if (config.PWA_ENABLE) { %>
  <link rel="manifest" href="<%= basePath %><%= config.PWA_MANIFEST %>">
  <link rel="apple-touch-icon" href="<%= basePath %><%= config.PWA_APPLE_TOUCH_ICON %>">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="<%= config.BLOG_NAME %>">
  <% } %>
  <% if (config.OG_ENABLE) { %>
  <meta property="og:title" content="<%= typeof title !== 'undefined' && title ? title : config.BLOG_NAME %>">
  <meta property="og:site_name" content="<%= config.BLOG_NAME %>">
  <meta property="og:type" content="<%= typeof title !== 'undefined' && title ? 'article' : 'website' %>">
  <meta property="og:url" content="<%= basePath %>/">
  <meta name="twitter:card" content="<%= config.OG_TWITTER_CARD %>">
  <% if (config.OG_TWITTER_ID) { %><meta name="twitter:site" content="<%= config.OG_TWITTER_ID %>"><% } %>
  <% if (config.OG_FB_APP_ID) { %><meta property="fb:app_id" content="<%= config.OG_FB_APP_ID %>"><% } %>
  <% if (config.INDEX_IMG) { %><meta property="og:image" content="<%= url(config.INDEX_IMG) %>"><% } %>
  <% } %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-screen-webfont@1.7.0/style.min.css">
  <link rel="stylesheet" href="<%= config.CDN.FONT_AWESOME %>" crossorigin="anonymous">
  <link rel="stylesheet" href="<%= basePath %>/assets/main.css?v=<%= typeof cssVersion !== 'undefined' ? cssVersion : '1' %>" onerror="this.onerror=null;this.href='<%= basePath %>/css/style.css'">
  <link rel="stylesheet" href="<%= config.CDN.KATEX_CSS %>" crossorigin="anonymous">

  <style>
    :root {
      --bg: <%= config.THEME?.colors?.light?.bg || '#f5f5f5' %>;
      --bg-card: <%= config.THEME?.colors?.light?.bg_card || '#ffffff' %>;
      --text: <%= config.THEME?.colors?.light?.text || '#2c3e50' %>;
      --text-secondary: <%= config.THEME?.colors?.light?.text_secondary || '#666666' %>;
      --text-muted: <%= config.THEME?.colors?.light?.text_muted || '#999999' %>;
      --border: <%= config.THEME?.colors?.light?.border || 'rgba(0,0,0,0.08)' %>;
      --accent: <%= config.THEME?.colors?.light?.accent || '#3498db' %>;
      --accent-light: <%= config.THEME?.colors?.light?.accent_light || 'rgba(52,152,219,0.1)' %>;
      --shadow: <%= config.THEME?.colors?.light?.shadow || '0 2px 12px rgba(0,0,0,0.06)' %>;
      --shadow-hover: <%= config.THEME?.colors?.light?.shadow_hover || '0 12px 32px rgba(0,0,0,0.1)' %>;
      --hero-gradient: <%= config.THEME?.hero_gradient || 'linear-gradient(135deg, #1a1a2e 0%, #16213e 40%, #0f3460 100%)' %>;
      --max-width: <%= config.THEME?.layout?.max_width || 1200 %>px;
      --sidebar-width: <%= config.THEME?.layout?.sidebar_width || 300 %>px;
      --post-sidebar-width: <%= config.THEME?.layout?.post_sidebar_width || 280 %>px;
      --header-height: <%= config.THEME?.layout?.header_height || 60 %>px;
      --hero-height: <%= config.THEME?.layout?.hero_height || 420 %>px;
      --cover-height: <%= config.THEME?.layout?.cover_height || 220 %>px;
      --font-body: <%= config.FONT_BODY %>;
      --font-code: <%= config.FONT_CODE %>;
      <% if (config.FONT_GLOBAL_SIZE) { %>--font-size-global: <%= config.FONT_GLOBAL_SIZE %>px;<% } %>
      <% if (config.FONT_CODE_SIZE) { %>--font-size-code: <%= config.FONT_CODE_SIZE %>px;<% } %>
      <% if (!config.ROUNDED_CORNERS) { %>--radius: 0px; --radius-sm: 0px; --radius-lg: 0px;<% } %>
    }
    [data-theme="dark"] {
      --bg: <%= config.THEME?.colors?.dark?.bg || '#1a1a2e' %>;
      --bg-card: <%= config.THEME?.colors?.dark?.bg_card || '#16213e' %>;
      --text: <%= config.THEME?.colors?.dark?.text || '#e0e0e0' %>;
      --text-secondary: <%= config.THEME?.colors?.dark?.text_secondary || '#b0b0b0' %>;
      --text-muted: <%= config.THEME?.colors?.dark?.text_muted || '#888888' %>;
      --border: <%= config.THEME?.colors?.dark?.border || 'rgba(255,255,255,0.08)' %>;
      --accent: <%= config.THEME?.colors?.dark?.accent || '#5dade2' %>;
      --accent-light: <%= config.THEME?.colors?.dark?.accent_light || 'rgba(93,173,226,0.15)' %>;
      --shadow: <%= config.THEME?.colors?.dark?.shadow || '0 2px 12px rgba(0,0,0,0.3)' %>;
      --shadow-hover: <%= config.THEME?.colors?.dark?.shadow_hover || '0 12px 32px rgba(0,0,0,0.4)' %>;
    }
  </style>

  <% if (config.PRELOADER_ENABLE) { %>
  <style>
    #preloader {
      position: fixed; inset: 0; z-index: 99999;
      background: var(--bg);
      display: flex; align-items: center; justify-content: center;
      transition: opacity 0.5s;
    }
    #preloader.hide { opacity: 0; pointer-events: none; }
    #preloader .loader {
      --color: var(--accent);
      --size-mid: 40px;
      --size-dot: 10px;
      --size-bar: 3px;
      --size-square: 24px;
      display: block;
      position: relative;
      width: 60px;
      height: 60px;
    }
    #preloader .loader::before,
    #preloader .loader::after {
      content: '';
      box-sizing: border-box;
      position: absolute;
    }
    #preloader .loader.--1::before {
      width: var(--size-mid); height: var(--size-mid);
      border: 4px solid var(--color);
      border-top-color: transparent;
      border-radius: 50%;
      left: 50%; top: 50%; transform: translate(-50%,-50%);
      animation: l1 1s linear infinite;
    }
    #preloader .loader.--1::after {
      width: calc(var(--size-mid) - 2px); height: calc(var(--size-mid) - 2px);
      border: 2px solid transparent;
      border-top-color: var(--color);
      border-radius: 50%;
      left: 50%; top: 50%; transform: translate(-50%,-50%);
      animation: l1 0.6s linear reverse infinite;
    }
    @keyframes l1 { to { transform: translate(-50%,-50%) rotate(360deg); } }
    #preloader .loader.--2::before,
    #preloader .loader.--2::after {
      width: var(--size-dot); height: var(--size-dot);
      background-color: var(--color); border-radius: 50%;
      opacity: 0;
      animation: l2 0.8s cubic-bezier(0.2,0.32,0,0.87) infinite;
    }
    #preloader .loader.--2::after { animation-delay: 0.3s; }
    @keyframes l2 {
      0%,80%,100% { opacity: 0; }
      33% { opacity: 1; }
      0%,100% { transform: translateX(-24px); }
      90% { transform: translateX(24px); }
    }
    #preloader .loader.--3::before,
    #preloader .loader.--3::after {
      width: var(--size-dot); height: var(--size-dot);
      background-color: var(--color); border-radius: 50%;
      top: 50%;
      animation: l3 1.2s ease-in-out infinite;
    }
    #preloader .loader.--3::before { left: calc(50% - 16px); }
    #preloader .loader.--3::after { left: calc(50% + 8px); animation-delay: -0.4s; }
    @keyframes l3 {
      0%,100% { transform: translateY(-20px); }
      44% { transform: translateY(20px); }
    }
    #preloader .loader.--4::before {
      height: var(--size-bar); width: 40px;
      background-color: var(--color);
      left: 50%; top: 50%; transform-origin: left;
      animation: l4 0.8s cubic-bezier(0,0,0.03,0.9) infinite;
    }
    @keyframes l4 {
      0%,44%,88.1%,100% { transform-origin: left; }
      0%,100%,88% { transform: scaleX(0); }
      44.1%,88% { transform-origin: right; }
      33%,44% { transform: scaleX(1); }
    }
    #preloader .loader.--5::before,
    #preloader .loader.--5::after {
      height: 20px; width: var(--size-bar);
      background-color: var(--color);
      animation: l5 0.6s cubic-bezier(0,0,0.03,0.9) infinite;
    }
    #preloader .loader.--5::before { left: calc(50% - 8px); top: calc(50% - 24px); }
    #preloader .loader.--5::after { left: calc(50% + 8px); top: calc(50% - 8px); animation-delay: 0.2s; }
    @keyframes l5 {
      0%,88%,100% { opacity: 0; }
      0% { transform: translateY(-40px); }
      33% { opacity: 1; }
      33%,88% { transform: translateY(20px); }
    }
    #preloader .loader.--6::before,
    #preloader .loader.--7::before {
      width: var(--size-square); height: var(--size-square);
      background-color: var(--color);
      top: calc(50% - var(--size-square)); left: calc(50% - var(--size-square));
      animation: l6 2.4s cubic-bezier(0,0,0.24,1.21) infinite;
    }
    @keyframes l6 {
      0%,100% { transform: none; }
      25% { transform: translateX(100%); }
      50% { transform: translateX(100%) translateY(100%); }
      75% { transform: translateY(100%); }
    }
    #preloader .loader.--7::after {
      width: var(--size-square); height: var(--size-square);
      background-color: var(--color);
      top: 50%; left: 50%;
      animation: l7 2.4s cubic-bezier(0,0,0.24,1.21) infinite;
    }
    @keyframes l7 {
      0%,100% { transform: none; }
      25% { transform: translateX(-100%); }
      50% { transform: translateX(-100%) translateY(-100%); }
      75% { transform: translateY(-100%); }
    }
    #preloader .loader.--8::before,
    #preloader .loader.--8::after {
      width: var(--size-dot); height: var(--size-dot);
      border-radius: 50%; background-color: var(--color);
    }
    #preloader .loader.--8::before {
      top: calc(50% + 30px);
      animation: l8-1 0.8s cubic-bezier(0.06,0.01,0.49,1.18) infinite;
    }
    @keyframes l8-1 {
      0%,55%,100% { opacity: 0; }
      0% { transform: scale(0.2); }
      22% { opacity: 1; }
      33%,55% { transform: scale(1) translateY(-40px); }
    }
    #preloader .loader.--8::after {
      opacity: 0; top: calc(50% - 12px);
      animation: l8-2 0.8s cubic-bezier(0.46,-0.1,0.27,1.07) 0.2s infinite;
    }
    @keyframes l8-2 {
      0%,100% { opacity: 0; }
      33% { opacity: 0.3; }
      0% { transform: scale(0); }
      100% { transform: scale(4); }
    }
    #preloader .loader.--9::before,
    #preloader .loader.--9::after {
      width: var(--size-dot); height: var(--size-dot);
      border-radius: 50%; background-color: var(--color);
      top: 50%;
      animation: l9 0.42s cubic-bezier(0.39,0.31,0,1.11) infinite;
    }
    #preloader .loader.--9::before { left: calc(50% - 20px); }
    #preloader .loader.--9::after { left: calc(50% + 12px); animation-delay: 0.12s; }
    @keyframes l9 {
      0%,100% { opacity: 0; }
      0% { transform: translate(-24px,-24px); }
      66% { opacity: 1; }
      66%,100% { transform: none; }
    }
  </style>
  <% } %>
<script>try{!function(){var k='blog_font_settings',s;try{s=JSON.parse(localStorage.getItem(k))}catch(e){}if(!s)return;var d=document.documentElement;if(s.fontSize)d.style.setProperty('--font-size-global',s.fontSize+'px');if(s.bodyFont&&s.bodyFont!=='unset')d.style.setProperty('--font-body',"'"+s.bodyFont+"'");else d.style.removeProperty('--font-body');if(s.codeFont&&s.codeFont!=='unset'){d.style.setProperty('--font-code',"'"+s.codeFont+"'");var cs=document.createElement('style');cs.id='__code_font_style';var fn=s.codeFont.replace(/"/g,'\\"');cs.textContent='@font-face{font-family:"'+fn+'";src:local("'+fn+'")}code,pre,.editor-gutter,#editor-input,textarea,.code-wrap,.highlight,.hljs{font-family:"'+fn+'",monospace!important}';document.head.appendChild(cs);var gl=document.createElement('link');gl.rel='stylesheet';gl.id='__code_font_gf';gl.href='https://fonts.googleapis.com/css2?family='+encodeURIComponent(s.codeFont)+':wght@300;400;500;600;700&display=swap';document.head.appendChild(gl)}else{d.style.removeProperty('--font-code');var og=document.getElementById('__code_font_gf');if(og)og.remove()}if(s.bodyFont&&s.bodyFont!=='unset'){var bs=document.createElement('style');bs.id='__body_font_style';var fnB=s.bodyFont.replace(/"/g,'\\"');bs.textContent='@font-face{font-family:"'+fnB+'";src:local("'+fnB+'")}body,.post-content,.content{font-family:"'+fnB+'",serif!important}';document.head.appendChild(bs);var bl=document.createElement('link');bl.rel='stylesheet';bl.id='__body_font_gf';bl.href='https://fonts.googleapis.com/css2?family='+encodeURIComponent(s.bodyFont)+':wght@300;400;500;600;700&display=swap';document.head.appendChild(bl)}else{var bs2=document.getElementById('__body_font_style');if(bs2)bs2.textContent='';var bg=document.getElementById('__body_font_gf');if(bg)bg.remove()}}()}catch(e){}</script>
</head>
<body>
  <% if (config.PRELOADER_ENABLE) { %>
  <div id="preloader"><div class="loader" id="loaderEl"></div></div>
  <script>
    (function(){var e=document.getElementById('loaderEl');if(e)e.classList.add('--'+Math.floor(Math.random()*9+1));})();
    window.addEventListener('load',function(){var p=document.getElementById('preloader');if(p)setTimeout(function(){p.classList.add('hide')},300)});
  </script>
  <% } %>

  <div class="progress-bar" id="progressBar"></div>

  <!-- Mobile sidebar -->
  <% if (config.ASIDE_MOBILE) { %>
  <div id="sidebar">
    <div id="menu-mask"></div>
    <div id="sidebar-menus">
      <div class="avatar-img text-center">
        <img src="<%= url(config.AVATAR_IMG) || '/img/avatar.png' %>" alt="<%= config.BLOG_AUTHOR %>">
      </div>
      <div class="site-data text-center">
        <a href="<%= basePath %>/archives/"><div class="headline"><%= locale.sidebar?.post_count_label || '文章' %></div><div class="length-num"><%= typeof postCount !== 'undefined' ? postCount : 0 %></div></a>
        <a href="<%= basePath %>/tags/"><div class="headline"><%= locale.sidebar?.tag_count_label || '标签' %></div><div class="length-num"><%= typeof allTags !== 'undefined' ? allTags.length : 0 %></div></a>
        <a href="<%= basePath %>/categories/"><div class="headline"><%= locale.sidebar?.category_count_label || '分类' %></div><div class="length-num"><%= typeof allCategories !== 'undefined' ? allCategories.length : 0 %></div></a>
      </div>
      <div class="menus_items">
        <% (config.NAV_MENU || []).forEach(function(item) { %>
          <% if (item.children && item.children.length > 0) { %>
          <div class="menus_item">
            <span class="site-page group"><i class="<%= item.icon %>"></i><span> <%= item.label %></span><i class="fas fa-chevron-down"></i></span>
            <ul class="menus_item_child">
              <% item.children.forEach(function(child) { %>
                <li><a class="site-page child" href="<%= basePath %><%= child.path %>"><i class="<%= child.icon %>"></i><span> <%= child.label %></span></a></li>
              <% }) %>
            </ul>
          </div>
          <% } else { %>
          <div class="menus_item">
            <a class="site-page" href="<%= basePath %><%= item.path %>"><i class="<%= item.icon %>"></i><span> <%= item.label %></span></a>
          </div>
          <% } %>
        <% }) %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Page Header -->
  <% if (typeof pageType !== 'undefined' && pageType === 'home') { %>
  <header class="full_page" id="page-header" style="<%= !config.DISABLE_TOP_IMG ? 'background-image: url(' + (config.INDEX_IMG || '') + '); background-size: cover; background-position: center;' : '' %>">
    <nav id="nav">
      <span id="blog-info">
        <a class="nav-site-title" href="<%= basePath %>/">
          <% if (config.NAV_LOGO) { %><img class="site-icon" src="<%= url(config.NAV_LOGO) %>" alt="Logo"><% } %>
          <% if (config.NAV_DISPLAY_TITLE) { %><span class="site-name"><%= config.BLOG_NAME %></span><% } %>
        </a>
        <span class="greeting-wrapper">
          <span class="greeting-text" id="greetingText"></span>
        </span>
      </span>
      <div id="menus">
        <div class="menus_items">
          <% (config.NAV_MENU || []).forEach(function(item) { %>
            <% if (item.children && item.children.length > 0) { %>
            <div class="menus_item">
              <span class="site-page group"><i class="<%= item.icon %>"></i><span> <%= item.label %></span><i class="fas fa-chevron-down"></i></span>
              <ul class="menus_item_child">
                <% item.children.forEach(function(child) { %>
                  <li><a class="site-page child" href="<%= basePath %><%= child.path %>"><i class="<%= child.icon %>"></i><span> <%= child.label %></span></a></li>
                <% }) %>
              </ul>
            </div>
            <% } else { %>
            <div class="menus_item">
              <a class="site-page" href="<%= basePath %><%= item.path %>"><i class="<%= item.icon %>"></i><span> <%= item.label %></span></a>
            </div>
            <% } %>
          <% }) %>
          <% if (config.SEARCH_ENABLE) { %>
          <div class="menus_item">
            <button id="searchBtn" class="site-page" title="<%= locale.search?.title || '搜索' %>"><i class="fas fa-search"></i><span> <%= locale.search?.title || '搜索' %></span></button>
          </div>
          <% } %>
        <div id="toggle-menu"><span class="site-page"><i class="fas fa-bars fa-fw"></i></span></div>
      </div>
    </nav>
    <div id="site-info">
      <h1 id="site-title"><%= config.BLOG_NAME %></h1>
      <div id="site-subtitle"><span id="subtitle"><%= config.BLOG_SUBTITLE %></span></div>
      <% if (config.INDEX_SUBTITLE_ENABLE && config.INDEX_SUBTITLE_SUB.length > 0) { %>
      <script>
        var subtitleStrings = <%- JSON.stringify(config.INDEX_SUBTITLE_SUB) %>;
        var subtitleEl = document.getElementById('subtitle');
        var subCharIdx = 0, subStrIdx = 0, subDeleting = false;
        var subSpeed = <%= config.INDEX_SUBTITLE_TYPE_SPEED %>, subBack = <%= config.INDEX_SUBTITLE_BACK_SPEED %>, subPause = <%= config.INDEX_SUBTITLE_PAUSE_TIME %>;
        function subType() {
          var cur = subtitleStrings[subStrIdx];
          if (subDeleting) {
            subtitleEl.textContent = cur.substring(0, subCharIdx--) + '|';
            if (subCharIdx < 0) { subDeleting = false; subStrIdx = (subStrIdx + 1) % subtitleStrings.length; subCharIdx = 0; setTimeout(subType, 500); return; }
            setTimeout(subType, subBack);
          } else {
            subtitleEl.textContent = cur.substring(0, ++subCharIdx) + '|';
            if (subCharIdx === cur.length) { subDeleting = true; setTimeout(subType, subPause); return; }
            setTimeout(subType, subSpeed);
          }
        }
        function subStart() { subType(); }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', subStart);
        else subStart();
      </script>
      <% } %>
      <div id="site_social_icons">
        <% if (config.SOCIAL_GITHUB) { %><a class="social-icon" href="<%= config.SOCIAL_GITHUB %>" target="_blank" title="Github"><i class="fab fa-github"></i></a><% } %>
        <% if (config.SOCIAL_WEIBO) { %><a class="social-icon" href="<%= config.SOCIAL_WEIBO %>" target="_blank" title="微博"><i class="fab fa-weibo"></i></a><% } %>
        <% if (config.SOCIAL_TWITTER) { %><a class="social-icon" href="<%= config.SOCIAL_TWITTER %>" target="_blank" title="Twitter"><i class="fab fa-twitter"></i></a><% } %>
        <% if (config.SOCIAL_EMAIL) { %><a class="social-icon" href="mailto:<%= config.SOCIAL_EMAIL %>" target="_blank" title="邮箱"><i class="fas fa-envelope"></i></a><% } %>
      </div>
    </div>
    <div id="scroll-down"><i class="fas fa-angle-down scroll-down-effects"></i></div>
  </header>
  <% } else { %>
  <% var headerBg = (typeof top_img !== 'undefined' && top_img) ? url(top_img) : ''; %>
  <header class="not-home-page" id="page-header" style="<%= headerBg ? 'background-image: url(' + headerBg + ');background-size:cover;background-position:center;' : '' %>">
    <nav id="nav">
      <span id="blog-info">
        <a class="nav-site-title" href="<%= basePath %>/">
          <% if (config.NAV_LOGO) { %><img class="site-icon" src="<%= url(config.NAV_LOGO) %>" alt="Logo"><% } %>
          <% if (config.NAV_DISPLAY_TITLE) { %><span class="site-name"><%= config.BLOG_NAME %></span><% } %>
        </a>
        <a class="nav-page-title" href="<%= basePath %>/">
          <span class="site-name"><%= typeof title !== 'undefined' && title ? title : config.BLOG_NAME %></span>
        </a>
      </span>
      <div id="menus">
        <div class="menus_items">
          <% (config.NAV_MENU || []).forEach(function(item) { %>
            <% if (item.children && item.children.length > 0) { %>
            <div class="menus_item">
              <span class="site-page group"><i class="<%= item.icon %>"></i><span> <%= item.label %></span><i class="fas fa-chevron-down"></i></span>
              <ul class="menus_item_child">
                <% item.children.forEach(function(child) { %>
                  <li><a class="site-page child" href="<%= basePath %><%= child.path %>"><i class="<%= child.icon %>"></i><span> <%= child.label %></span></a></li>
                <% }) %>
              </ul>
            </div>
            <% } else { %>
            <div class="menus_item">
               <a class="site-page" href="<%= basePath %><%= item.path %>"><i class="<%= item.icon %>"></i><span> <%= item.label %></span></a>
             </div>
             <% } %>
           <% }) %>
           <% if (config.SEARCH_ENABLE) { %>
           <div class="menus_item">
             <button id="searchBtn" class="site-page search-btn-alt" title="<%= locale.search?.title || '搜索' %>"><i class="fas fa-search"></i><span> <%= locale.search?.title || '搜索' %></span></button>
           </div>
           <% } %>
          </div>
        <div id="toggle-menu"><span class="site-page"><i class="fas fa-bars fa-fw"></i></span></div>
      </div>
    </nav>
    <% if (typeof post !== 'undefined' && post) { %>
    <div id="post-info">
      <h1 class="post-title"><%= typeof title !== 'undefined' && title ? title : config.BLOG_NAME %></h1>
      <div id="post-meta">
        <div class="meta-firstline">
          <span class="post-meta-date">
            <% var dateType = (config.POST_META?.post?.date_type || 'both'); %>
            <i class="far fa-calendar-alt fa-fw post-meta-icon"></i>
            <span class="post-meta-label"><%= locale.post?.published_at || '发表于' %></span>
            <time class="post-meta-date-created" datetime="<%= post.created_at %>"><%= formatDate(post.created_at) %></time>
            <% if (dateType !== 'created') { %>
            <span class="post-meta-separator">|</span>
            <i class="fas fa-history fa-fw post-meta-icon"></i>
            <span class="post-meta-label"><%= locale.post?.updated_at || '更新于' %></span>
            <time class="post-meta-date-updated" datetime="<%= post.updated_at %>"><%= formatDate(post.updated_at) %></time>
            <% } %>
          </span>
          <% if (post.category) { %>
          <% var catParts = post.category.split('/').filter(Boolean); %>
          <span class="post-meta-categories">
            <span class="post-meta-separator">|</span>
            <% catParts.forEach(function(part, idx) { %>
            <% if (idx > 0) { %>
            <i class="fas fa-angle-right post-meta-separator"></i>
            <% } %>
            <i class="fas fa-inbox fa-fw post-meta-icon"></i>
            <a class="post-meta-categories" href="<%= basePath %>/categories/<%= catParts.slice(0, idx+1).map(encodeURIComponent).join('/') %>/"><%= part %></a>
            <% }); %>
          </span>
          <% } %>
        </div>
        <div class="meta-secondline">
          <span class="post-meta-separator">|</span>
          <span class="post-meta-wordcount">
            <i class="far fa-file-word fa-fw post-meta-icon"></i>
            <span class="post-meta-label"><%= locale.post?.word_count_label || '总字数:' %></span>
            <%
              var wc = post.word_count || post.content.length;
              var wcDisplay = wc >= 1000 ? (wc / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : wc;
            %>
            <span class="word-count"><%= wcDisplay %></span>
            <span class="post-meta-separator">|</span>
            <i class="far fa-clock fa-fw post-meta-icon"></i>
            <span class="post-meta-label"><%= locale.post?.reading_time || '阅读时长:' %></span>
            <span><%= Math.ceil(post.content.length / config.READING_SPEED) || 1 %><%= locale.post?.reading_time_unit || '分钟' %></span>
          </span>
          <span class="post-meta-separator">|</span>
          <span class="post-meta-pv-cv" id="post-pv-display" data-flag-title="">
            <i class="far fa-eye fa-fw post-meta-icon"></i>
            <span class="post-meta-label"><%= locale.sidebar?.webinfo_total_views || '浏览量:' %></span>
            <span id="post-view-count"><i class="fa-solid fa-spinner fa-spin"></i></span>
          </span>
        </div>
      </div>
      <% if (config.POST_META?.post?.tags !== false && post.tags && post.tags.length > 0) { %>
      <div class="post-tags">
        <% post.tags.forEach(function(t) { %>
          <% var tagEnc = encodeURIComponent(t) %>
          <a href="<%= basePath %><%= isStatic ? '/tag/' + tagEnc + '/' : '/?tag=' + tagEnc %>" class="tag-pill"><i class="fas fa-tag"></i> <%= t %></a>
        <% }) %>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <div id="page-site-info">
      <h1 id="site-title"><%= typeof title !== 'undefined' && title ? title : config.BLOG_NAME %></h1>
      <% if (typeof subtitle !== 'undefined' && subtitle) { %>
      <div id="site-subtitle"><%= subtitle %></div>
      <% } %>
    </div>
    <% } %>
  </header>
  <% } %>

  <div class="page" id="body-wrap">