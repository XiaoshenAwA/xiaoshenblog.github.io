<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title + ' | ' : '' %>MyBlog</title>
  <link rel="stylesheet" href="<%= basePath %>/assets/main.css" onerror="this.onerror=null;this.href='<%= basePath %>/css/style.css'">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.17.0/dist/katex.min.css" crossorigin="anonymous">
</head>
<body>
  <div class="progress-bar" id="progressBar"></div>

  <header class="site-header">
    <div class="header-container">
      <a href="<%= basePath %>/" class="site-logo"><i class="fas fa-feather-alt"></i> MyBlog</a>
      <nav class="site-nav">
        <a href="<%= basePath %>/"><i class="fas fa-home"></i> <span>首页</span></a>
        <a href="<%= basePath %>/editor"><i class="fas fa-pen"></i> <span>Markdown 编辑器</span></a>
        <a href="<%= basePath %>/about"><i class="fas fa-user"></i> <span>关于</span></a>
        <button class="theme-toggle" id="themeToggle" title="切换主题">
          <i class="fas fa-moon"></i>
        </button>
      </nav>
      <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
    </div>
  </header>

  <div class="mobile-menu" id="mobileMenu">
    <a href="<%= basePath %>/"><i class="fas fa-home"></i> 首页</a>
    <a href="<%= basePath %>/editor"><i class="fas fa-pen"></i> Markdown 编辑器</a>
    <a href="<%= basePath %>/about"><i class="fas fa-user"></i> 关于</a>
  </div>