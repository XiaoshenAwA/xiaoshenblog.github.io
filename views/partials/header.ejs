<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title + ' | ' : '' %>MyBlog</title>
  <link rel="preconnect" href="https://cdnjs.cloudflare.com">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/katex.min.css" media="print" onload="this.media='all'">
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Noto+Serif+SC:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/katex.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Noto+Serif+SC:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
  </noscript>
  <link rel="stylesheet" href="<%= basePath %>/css/style.css">
</head>
<body>
  <div class="progress-bar" id="progressBar"></div>

  <header class="site-header">
    <div class="header-container">
      <a href="<%= basePath %>/" class="site-logo"><i class="fas fa-feather-alt"></i> MyBlog</a>
      <nav class="site-nav">
        <a href="<%= basePath %>/"><i class="fas fa-home"></i> <span>首页</span></a>
        <% if (!isStatic) { %>
          <a href="<%= basePath %>/posts/new"><i class="fas fa-pen"></i> <span>写文章</span></a>
        <% } %>
        <a href="<%= basePath %>/about"><i class="fas fa-user"></i> <span>关于</span></a>
        <button class="theme-toggle" id="themeToggle" title="切换主题">
          <i class="fas fa-moon"></i>
        </button>
      </nav>
      <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
    </div>
  </header>

  <div class="mobile-menu" id="mobileMenu">
    <a href="<%= basePath %>/"><i class="fas fa-home"></i> 首页</a>
    <% if (!isStatic) { %>
      <a href="<%= basePath %>/posts/new"><i class="fas fa-pen"></i> 写文章</a>
    <% } %>
    <a href="<%= basePath %>/about"><i class="fas fa-user"></i> 关于</a>
  </div>
