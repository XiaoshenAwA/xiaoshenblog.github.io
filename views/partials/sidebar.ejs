<% if (config.ASIDE_CARD_AUTHOR) { %>
<div class="card-widget card-info text-center" id="profileCard">
      <div class="avatar-img">
        <img src="<%= url(config.AVATAR_IMG) || '/img/avatar.png' %>" alt="<%= config.BLOG_AUTHOR %>"<%= config.AVATAR_EFFECT ? ' class="avatar-effect"' : '' %>>
      </div>
      <div class="author-info-name"><%= config.BLOG_AUTHOR %></div>
      <div class="author-info-description"><%= config.BLOG_AUTHOR_BIO %></div>
      <div class="site-data">
        <a href="<%= basePath %>/archives/"><div class="headline"><%= locale.sidebar?.post_count_label || '文章' %></div><div class="length-num"><%= typeof postCount !== 'undefined' ? postCount : 0 %></div></a>
        <a href="<%= basePath %>/tags/"><div class="headline"><%= locale.sidebar?.tag_count_label || '标签' %></div><div class="length-num"><%= typeof allTags !== 'undefined' ? allTags.length : 0 %></div></a>
        <a href="<%= basePath %>/categories/"><div class="headline"><%= locale.sidebar?.category_count_label || '分类' %></div><div class="length-num"><%= typeof allCategories !== 'undefined' ? allCategories.length : 0 %></div></a>
      </div>
      <%
        var followPlatform = config.ASIDE_FOLLOW_ME_PLATFORM || 'github';
        var followUrl = '';
        var followIcon = '';
        if (followPlatform === 'github' && config.SOCIAL_GITHUB) { followUrl = config.SOCIAL_GITHUB; followIcon = 'fab fa-github'; }
        else if (followPlatform === 'twitter' && config.SOCIAL_TWITTER) { followUrl = config.SOCIAL_TWITTER; followIcon = 'fab fa-twitter'; }
        else if (followPlatform === 'weibo' && config.SOCIAL_WEIBO) { followUrl = config.SOCIAL_WEIBO; followIcon = 'fab fa-weibo'; }
        else if (followPlatform === 'email' && config.SOCIAL_EMAIL) { followUrl = 'mailto:' + config.SOCIAL_EMAIL; followIcon = 'fas fa-envelope'; }
        else { followUrl = config.SOCIAL_GITHUB; followIcon = 'fab fa-github'; }
      %>
      <% if (followUrl) { %>
      <a id="card-info-btn" target="_blank" rel="noopener" href="<%= followUrl %>"><i class="<%= followIcon %>"></i><span><%= locale.nav?.follow_me || '关注我' %></span></a>
      <% } %>
      <div class="card-info-social-icons">
        <% if (config.SOCIAL_GITHUB) { %><a class="social-icon" href="<%= config.SOCIAL_GITHUB %>" target="_blank" title="Github"><i class="fab fa-github"></i></a><% } %>
        <% if (config.SOCIAL_WEIBO) { %><a class="social-icon" href="<%= config.SOCIAL_WEIBO %>" target="_blank" title="微博"><i class="fab fa-weibo"></i></a><% } %>
        <% if (config.SOCIAL_TWITTER) { %><a class="social-icon" href="<%= config.SOCIAL_TWITTER %>" target="_blank" title="Twitter"><i class="fab fa-twitter"></i></a><% } %>
        <% if (config.SOCIAL_EMAIL) { %><a class="social-icon" href="mailto:<%= config.SOCIAL_EMAIL %>" target="_blank" title="邮箱"><i class="fas fa-envelope"></i></a><% } %>
      </div>
</div>
<% } %>

<% if (config.ASIDE_CARD_ANNOUNCEMENT && config.ASIDE_ANNOUNCEMENT_CONTENT) { %>
<div class="card-widget card-announcement">
  <div class="item-headline"><i class="fas fa-bullhorn fa-shake"></i><span><%= locale.sidebar?.announcement_title || '公告' %></span></div>
  <div class="announcement_content"><%= config.ASIDE_ANNOUNCEMENT_CONTENT %></div>
</div>
<% } %>

<div class="card-widget card-hitokoto" id="hitokotoCard">
  <div class="item-headline"><i class="fas fa-quote-left"></i><span>一言</span></div>
  <div class="hitokoto-content">
    <div class="hitokoto-text" id="hitokotoText">加载中...</div>
    <div class="hitokoto-from" id="hitokotoFrom"></div>
  </div>
  <div class="hitokoto-btn" onclick="fetchHitokoto()"><i class="fas fa-sync-alt"></i></div>
</div>

<div class="sticky_layout">
  <% if (config.ASIDE_CARD_RECENT_POST && typeof recentPosts !== 'undefined' && recentPosts.length > 0) { %>
  <div class="card-widget card-recent-post">
    <div class="item-headline"><i class="fas fa-history"></i><span><%= locale.sidebar?.recent_posts_title || '最新文章' %></span></div>
    <div class="aside-list">
      <% recentPosts.forEach(p => { %>
        <div class="aside-list-item">
          <a class="thumbnail" href="<%= basePath %>/posts/<%= p.id %>" title="<%= p.title %>">
            <% var _sbArr = Array.isArray(config.DEFAULT_COVER) ? config.DEFAULT_COVER : [config.DEFAULT_COVER || config.FALLBACK_COVER || 'https://t.alcy.cc/fj']; %>
            <% var _sbUrl = _sbArr[Math.floor(Math.random() * _sbArr.length)]; %>
            <img src="<%= p.cover || _sbUrl + (_sbUrl.includes('?') ? '&' : '?') + 'v=' + p.id %>" alt="<%= p.title %>">
          </a>
          <div class="content">
            <a class="title" href="<%= basePath %>/posts/<%= p.id %>" title="<%= p.title %>"><%= p.title %></a>
            <time datetime="<%= p.created_at %>"><%= formatDate(p.created_at) %></time>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <% if (config.ASIDE_CARD_CATEGORIES && typeof categoryTree !== 'undefined' && categoryTree.length > 0) { %>
  <div class="card-widget card-categories">
    <div class="item-headline">
      <i class="fas fa-folder-open"></i>
      <span><%= locale.sidebar?.categories_title || '分类' %></span>
      <a class="card-more-btn" href="<%= basePath %>/categories/" title="查看更多"><i class="fas fa-angle-right"></i></a>
    </div>
    <ul class="card-category-list" id="aside-cat-list">
      <% categoryTree.forEach(function(c) { %>
        <li class="card-category-list-item" data-level="<%= c.level %>" style="padding-left:<%= c.level * 16 %>px<%= c.level > 0 ? ';display:none' : '' %>">
          <% var hasChild = categoryTree.some(function(x) { return x.path.indexOf(c.path + '/') === 0; }); %>
          <% if (hasChild) { %><span class="cat-toggle" data-path="<%= c.path %>" style="cursor:pointer;display:inline-block;width:16px;text-align:center;font-size:0.75em;color:var(--accent);margin-right:4px"><i class="fas fa-chevron-right"></i></span><% } else { %><span style="display:inline-block;width:16px;margin-right:4px"></span><% } %>
          <a class="card-category-list-link" href="<%= basePath %>/categories/<%= c.path.split('/').map(function(s){return encodeURIComponent(s)}).join('/') %>/">
            <span class="card-category-list-name"><%= c.name %></span>
            <span class="card-category-list-count"><%= c.count %></span>
          </a>
        </li>
      <% }); %>
    </ul>
    <div style="margin-top:8px;text-align:center">
      <a href="<%= basePath %>/categories/" style="font-size:0.85em;color:var(--text-muted)"><i class="fas fa-folder-plus"></i> <%= locale.categories?.all_categories || '所有分类' %></a>
    </div>
  </div>
  <script>
    try {
      document.querySelectorAll('.cat-toggle').forEach(function(el) {
        el.addEventListener('click', function(e) {
          e.stopPropagation();
          var icon = el.querySelector('i');
          var expanded = icon.classList.contains('fa-chevron-down');
          icon.className = expanded ? 'fas fa-chevron-right' : 'fas fa-chevron-down';
          var parentLi = el.parentElement;
          var targetLevel = parseInt(parentLi.getAttribute('data-level'));
          var next = parentLi.nextElementSibling;
          while (next && next.classList.contains('card-category-list-item')) {
            var childLevel = parseInt(next.getAttribute('data-level'));
            if (childLevel > targetLevel) {
              next.style.display = expanded ? 'none' : '';
              next = next.nextElementSibling;
            } else break;
          }
        });
      });
    } catch(e) {}
  </script>
  <% } %>

  <% if (config.ASIDE_CARD_TAGS && typeof allTags !== 'undefined' && allTags.length > 0) { %>
  <div class="card-widget card-tags">
    <div class="item-headline"><i class="fas fa-tags"></i><span><%= locale.sidebar?.tags_title || '标签' %></span></div>
    <div class="card-tag-cloud">
      <% allTags.slice(0, config.ASIDE_TAGS_LIMIT || 30).forEach((t, ti) => { %>
        <% var tagEnc = encodeURIComponent(t) %>
        <a href="<%= basePath %><%= isStatic ? '/tag/' + tagEnc + '/' : '/?tag=' + tagEnc %>"<%= config.ASIDE_TAGS_COLOR ? ' style="color:hsl(' + ((ti * 137 + 220) % 360) + ',60%,45%)"' : '' %>><%= t %></a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <% if (config.ASIDE_CARD_ARCHIVES && typeof archives !== 'undefined' && archives.length > 0) { %>
  <div class="card-widget card-archives">
    <div class="item-headline">
      <i class="fas fa-archive"></i>
      <span><%= locale.sidebar?.archives_title || '归档' %></span>
    </div>
    <ul class="card-archive-list">
      <% archives.slice(0, config.ASIDE_ARCHIVES_LIMIT || 8).forEach(a => { %>
        <li class="card-archive-list-item">
          <a class="card-archive-list-link" href="<%= basePath %>/archives#<%= a.year %>-<%= a.month ? String(a.month).padStart(2,'0') : '' %>">
            <span class="card-archive-list-date"><%= a.year %> <%= locale.sidebar?.year_suffix || '年' %><%= a.month ? ' ' + a.month + ' ' + (locale.sidebar?.month_suffix || '月') : '' %></span>
            <span class="card-archive-list-count"><%= a.count %></span>
          </a>
        </li>
      <% }) %>
    </ul>
  </div>
  <% } %>

  <% if (config.ASIDE_CARD_WEBINFO) { %>
  <div class="card-widget card-webinfo">
    <div class="item-headline"><i class="fas fa-chart-line"></i><span><%= locale.sidebar?.webinfo_title || '网站信息' %></span></div>
    <div class="webinfo">
      <% if (config.ASIDE_WEBINFO_POST_COUNT) { %>
      <div class="webinfo-item">
        <div class="item-name"><%= locale.sidebar?.webinfo_post_count || '文章数目 :' %></div>
        <div class="item-count"><%= typeof postCount !== 'undefined' ? postCount : 0 %></div>
      </div>
      <% } %>
      <% if (config.ASIDE_WEBINFO_RUNTIME_DATE) { %>
      <div class="webinfo-item">
        <div class="item-name"><%= locale.sidebar?.webinfo_runtime || '运行时间 :' %></div>
        <div class="item-count runtime-days" data-start="<%= config.ASIDE_WEBINFO_RUNTIME_DATE %>"><%= locale.sidebar?.webinfo_runtime_loading || '计算中...' %></div>
      </div>
      <% } %>
      <div class="webinfo-item">
        <div class="item-name"><%= locale.sidebar?.webinfo_word_count || '本站总字数 :' %></div>
        <div class="item-count"><%= typeof totalWordCount !== 'undefined' ? (totalWordCount/1000).toFixed(1) + 'k' : 0 %></div>
      </div>
      <% if (config.ASIDE_WEBINFO_VISITOR_COUNT) { %>
      <div class="webinfo-item">
        <div class="item-name"><%= locale.sidebar?.webinfo_visitor_count || '本站访客数 :' %></div>
        <div class="item-count webinfo-visitor-count"><%= typeof visitorCount !== 'undefined' ? visitorCount : 0 %></div>
      </div>
      <% } %>
      <% if (config.ASIDE_WEBINFO_TOTAL_VIEWS) { %>
      <div class="webinfo-item">
        <div class="item-name"><%= locale.sidebar?.webinfo_total_views || '本站总浏览量 :' %></div>
        <div class="item-count webinfo-total-views"><%= typeof totalViews !== 'undefined' ? totalViews : 0 %></div>
      </div>
      <% } %>
      <% if (config.ASIDE_WEBINFO_LAST_UPDATE) { %>
      <div class="webinfo-item">
        <div class="item-name"><%= locale.sidebar?.webinfo_last_update || '最后更新时间 :' %></div>
        <div class="item-count last-update-time" data-time="<%= typeof lastUpdateTime !== 'undefined' && lastUpdateTime ? lastUpdateTime : '' %>"><%= locale.sidebar?.webinfo_last_update_loading || '计算中...' %></div>
      </div>
      <% } %>
    </div>
  </div>
  <% } %>
</div>