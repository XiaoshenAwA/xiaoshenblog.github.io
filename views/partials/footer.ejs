  </div><!-- #body-wrap -->

  <div class="jinrishici-container">
    <div class="jinrishici-text" id="jinrishiciText"></div>
    <div class="jinrishici-source" id="jinrishiciSource"></div>
  </div>

  <footer id="footer">
    <div id="footer-wrap">
      <% if (config.FOOTER_OWNER_ENABLE) { %>
      <div class="copyright">&copy;<%= config.FOOTER_OWNER_SINCE %> <%= locale.footer?.powered_by_label || 'By' %> <%= config.BLOG_AUTHOR %></div>
      <% } %>
      <% if (config.FOOTER_COPYRIGHT) { %>
      <div class="framework-info">
        <span><%= locale.footer?.framework_label || '框架' %> </span><a target="_blank" rel="noopener" href="https://expressjs.com">Express</a>
        <span class="footer-separator">|</span>
        <span><%= locale.footer?.theme_label || '主题' %> </span><a target="_blank" rel="noopener" href="https://github.com/jerryc127/hexo-theme-butterfly">Butterfly</a>
      </div>
      <% } %>
      <% if (config.FOOTER_CUSTOM_TEXT) { %>
        <div style="margin-top:8px;font-size:0.82em;color:var(--text-muted)"><%= config.FOOTER_CUSTOM_TEXT %></div>
      <% } %>
    </div>
  </footer>

  <div id="rightside">
    <div id="rightside-config-hide">
      <% if (config.DARKMODE_ENABLE && config.DARKMODE_BUTTON) { %><button id="darkmode" type="button" title="<%= locale.footer?.day_night_toggle || '日间和夜间模式切换' %>"><i class="fas fa-adjust"></i></button><% } %>
      <button id="hide-aside-btn" type="button" title="<%= locale.footer?.column_toggle || '单栏和双栏切换' %>"><i class="fas fa-arrows-alt-h"></i></button>
    <button id="font-settings-btn" type="button" title="<%= locale.footer?.font_settings || '字体设置' %>"><i class="fas fa-font"></i></button>
    </div>
    <div id="rightside-config-show">
      <button id="rightside-config" type="button" title="<%= locale.footer?.settings || '设置' %>"><i class="fas fa-cog fa-spin"></i></button>
      <button id="go-up" type="button" title="<%= locale.footer?.back_to_top || '回到顶部' %>"><span class="scroll-percent">0</span><i class="fas fa-arrow-up"></i></button>
    </div>
  </div>

  <script src="<%= basePath %>/assets/main.js?v=<%= typeof cssVersion !== 'undefined' ? cssVersion : '1' %>"></script>
  <script>
    try {
      var h = document.documentElement;
      <% if (config.DARKMODE_ENABLE) { %>
      var s = localStorage.getItem('theme');
      if (s) { h.setAttribute('data-theme', s); } else {
        <% if (config.DARKMODE_AUTO === 1) { %>
        if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) h.setAttribute('data-theme', 'dark');
        <% } else if (config.DARKMODE_AUTO === 2) { %>
        var hr = (new Date()).getHours(); var start = <%= config.DARKMODE_START %>; var end = <%= config.DARKMODE_END %>;
        if (start > end) { if (hr >= start || hr < end) h.setAttribute('data-theme', 'dark'); }
        else { if (hr >= start && hr < end) h.setAttribute('data-theme', 'dark'); }
        <% } %>
      }
      <% } %>
    } catch(e) {}

    try {
      var rt = document.querySelector('.runtime-days');
      if (rt) {
        var startDate = rt.getAttribute('data-start');
        if (startDate) {
          var start = new Date(startDate);
          var now = new Date();
          var days = Math.floor((now - start) / (1000 * 60 * 60 * 24));
          rt.textContent = days + ' 天';
        }
      }
    } catch(e) {}

    try {
      var lut = document.querySelector('.last-update-time');
      if (lut) {
        var timeStr = lut.getAttribute('data-time');
        if (timeStr) {
          var updateDate = new Date(timeStr);
          var now = new Date();
          var diffMs = now - updateDate;
          var diffMonths = Math.floor(diffMs / (1000 * 60 * 60 * 24 * 30));
          if (diffMonths < 1) {
            var diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
            lut.textContent = diffDays + ' 天前';
          } else if (diffMonths < 12) {
            lut.textContent = diffMonths + ' 个月前';
          } else {
            var diffYears = Math.floor(diffMonths / 12);
            lut.textContent = diffYears + ' 年前';
          }
        }
      }
    } catch(e) {}

    try {
      var today = new Date().toDateString();
      var lastVisit = localStorage.getItem('blog_last_visit');
      if (lastVisit !== today) {
        localStorage.setItem('blog_last_visit', today);
        <% if (typeof isStatic !== 'undefined' && isStatic) { %>
        fetch('<%= supabaseUrl %>/rest/v1/rpc/increment_stat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'apikey': '<%= supabaseAnonKey %>', 'Authorization': 'Bearer <%= supabaseAnonKey %>' },
          body: JSON.stringify({ stat_key: 'visitor_count' })
        });
        <% } else { %>
        fetch('<%= basePath %>/api/stats/visit', { method: 'POST' });
        <% } %>
      }
    } catch(e) {}

    /* 时间问候语 */
    try {
      var greetingEl = document.getElementById('greetingText');
      if (greetingEl) {
        var greetings = [
          { text: '🌙 夜深了，早点休息哦', start: 0, end: 5 },
          { text: '🌅 早上好，新的一天开始啦', start: 6, end: 8 },
          { text: '☀️ 上午好，工作顺利', start: 9, end: 11 },
          { text: '🍜 中午好，该吃饭啦', start: 11, end: 13 },
          { text: '☕ 下午好，喝杯咖啡吧', start: 14, end: 17 },
          { text: '🌆 傍晚好，放松一下', start: 18, end: 20 },
          { text: '🌃 晚上好，享受夜晚', start: 21, end: 23 }
        ];
        
        function updateGreeting() {
          var hour = new Date().getHours();
          for (var i = 0; i < greetings.length; i++) {
            if (hour >= greetings[i].start && hour <= greetings[i].end) {
              greetingEl.textContent = greetings[i].text;
              greetingEl.style.opacity = '0';
              setTimeout(function() {
                greetingEl.style.transition = 'opacity 0.5s';
                greetingEl.style.opacity = '1';
              }, 100);
              break;
            }
          }
        }
        
        updateGreeting();
        setInterval(updateGreeting, 60000);
      }
    } catch(e) {}

    /* 标题切换效果 */
    try {
      var originalTitle = document.title;
      document.addEventListener('visibilitychange', function() {
        if (document.hidden) {
          document.title = '(╥﹏╥) 不要走，再看看嘛～';
        } else {
          document.title = '(*^▽^*) 欢迎回来！';
          setTimeout(function() {
            document.title = originalTitle;
          }, 2000);
        }
      });
    } catch(e) {}

    /* 今日诗词打字机效果 */
    try {
      var poemTextEl = document.getElementById('jinrishiciText');
      var poemSourceEl = document.getElementById('jinrishiciSource');
      
      if (poemTextEl && poemSourceEl) {
        function fetchPoem() {
          fetch('https://v1.jinrishici.com/all.json')
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data && data.content) {
                typeWriter(data.content, data.origin || '');
              }
            })
            .catch(function() {
              typeWriter('人生得意须尽欢，莫使金樽空对月', '李白');
            });
        }
        
        function typeWriter(text, source) {
          poemTextEl.textContent = '';
          poemSourceEl.textContent = '';
          var index = 0;
          
          function type() {
            if (index < text.length) {
              poemTextEl.textContent += text.charAt(index);
              index++;
              setTimeout(type, 100 + Math.random() * 50);
            } else {
              setTimeout(function() {
                poemSourceEl.textContent = '—— ' + source;
                poemSourceEl.style.opacity = '1';
              }, 300);
            }
          }
          
          poemSourceEl.style.opacity = '0';
          type();
        }
        
        setTimeout(fetchPoem, 1000);
        setInterval(fetchPoem, 30000);
      }
    } catch(e) {}

    /* 一言卡片功能 (打字机效果) */
    try {
      var hitokotoTyping = false;

      window.fetchHitokoto = function() {
        if (hitokotoTyping) return;

        var textEl = document.getElementById('hitokotoText');
        var fromEl = document.getElementById('hitokotoFrom');
        
        if (!textEl || !fromEl) return;

        hitokotoTyping = true;
        textEl.style.opacity = '0';
        fromEl.style.opacity = '0';
        
        fetch('https://v1.hitokoto.cn/?c=i&c=d')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            setTimeout(function() {
              typeHitokoto(data.hitokoto, '—— 《' + data.from + '》');
            }, 300);
          })
          .catch(function() {
            setTimeout(function() {
              typeHitokoto('生活就像一盒巧克力，你永远不知道下一颗是什么味道。', '—— 《阿甘正传》');
            }, 300);
          });
      };

      function typeHitokoto(text, from) {
        var textEl = document.getElementById('hitokotoText');
        var fromEl = document.getElementById('hitokotoFrom');
        if (!textEl || !fromEl) return;

        textEl.textContent = '';
        textEl.style.opacity = '1';
        fromEl.style.opacity = '0';
        var index = 0;

        function type() {
          if (index < text.length) {
            textEl.textContent += text.charAt(index);
            index++;
            setTimeout(type, 80 + Math.random() * 40);
          } else {
            setTimeout(function() {
              fromEl.textContent = from;
              fromEl.style.transition = 'opacity 0.5s';
              fromEl.style.opacity = '1';
              hitokotoTyping = false;
            }, 400);
          }
        }

        type();
      }
      
      fetchHitokoto();
    } catch(e) {}

    /* 作者卡片翻转效果 - 已移除 */

    try {
      var postId = window.location.pathname.match(/\/posts\/(\d+)/);
      if (postId) {
        <% if (typeof isStatic !== 'undefined' && isStatic) { %>
        fetch('<%= supabaseUrl %>/rest/v1/rpc/increment_stat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'apikey': '<%= supabaseAnonKey %>', 'Authorization': 'Bearer <%= supabaseAnonKey %>' },
          body: JSON.stringify({ stat_key: 'total_views' })
        });
        <% } else { %>
        fetch('<%= basePath %>/api/stats/view/' + postId[1], { method: 'POST' });
        <% } %>
      }
    } catch(e) {}

    try {
      var pvEl = document.getElementById('post-view-count');
      if (pvEl) {
        <% if (typeof isStatic !== 'undefined' && isStatic) { %>
        fetch('<%= supabaseUrl %>/rest/v1/site_stats?select=key,value', {
          headers: { 'apikey': '<%= supabaseAnonKey %>', 'Authorization': 'Bearer <%= supabaseAnonKey %>' }
        }).then(function(r) { return r.json(); }).then(function(rows) {
          var stats = {};
          (rows || []).forEach(function(r) { stats[r.key] = r.value; });
          pvEl.textContent = stats.total_views || 0;
        })['catch'](function() { pvEl.textContent = '-'; });
        <% } else { %>
        fetch('<%= basePath %>/api/stats').then(function(r) { return r.json(); }).then(function(d) {
          pvEl.textContent = d.total_views || 0;
        })['catch'](function() { pvEl.textContent = '-'; });
        <% } %>
      }
    } catch(e) {}

    try {
      var webinfoVisitor = document.querySelector('.webinfo-visitor-count');
      var webinfoViews = document.querySelector('.webinfo-total-views');
      if (webinfoVisitor || webinfoViews) {
        <% if (typeof isStatic !== 'undefined' && isStatic) { %>
        fetch('<%= supabaseUrl %>/rest/v1/site_stats?select=key,value', {
          headers: { 'apikey': '<%= supabaseAnonKey %>', 'Authorization': 'Bearer <%= supabaseAnonKey %>' }
        }).then(function(r) { return r.json(); }).then(function(rows) {
          var stats = {};
          (rows || []).forEach(function(r) { stats[r.key] = r.value; });
          if (webinfoVisitor) webinfoVisitor.textContent = stats.visitor_count || 0;
          if (webinfoViews) webinfoViews.textContent = stats.total_views || 0;
        })['catch'](function() {});
        <% } else { %>
        fetch('<%= basePath %>/api/stats').then(function(r) { return r.json(); }).then(function(d) {
          if (webinfoVisitor) webinfoVisitor.textContent = d.visitor_count || 0;
          if (webinfoViews) webinfoViews.textContent = d.total_views || 0;
        })['catch'](function() {});
        <% } %>
      }
    } catch(e) {}

    try {
      window.addEventListener('scroll', function() {
        var bar = document.getElementById('progressBar');
        if (!bar) return;
        var h = document.documentElement.scrollHeight - window.innerHeight;
        var p = h > 0 ? (window.scrollY / h) * 100 : 0;
        bar.style.width = p + '%';
      });
    } catch(e) {}

    try {
      var goUp = document.getElementById('go-up');
      var scrollPercent = goUp ? goUp.querySelector('.scroll-percent') : null;
      if (goUp) {
        goUp.addEventListener('click', function() {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
      window.addEventListener('scroll', function() {
        var h = document.documentElement.scrollHeight - window.innerHeight;
        var p = h > 0 ? Math.round((window.scrollY / h) * 100) : 0;
        if (scrollPercent) scrollPercent.textContent = p;
      });
    } catch(e) {}

    <% if (config.CB_COPY) { %>
    try {
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.copy-btn');
        if (!btn) return;
        var fig = btn.closest('.highlight');
        var codeEl = fig.querySelector('pre.code-wrap code');
        if (!codeEl) return;
        var text = codeEl.textContent;
        navigator.clipboard.writeText(text).then(function() {
          var orig = btn.textContent;
          btn.textContent = '<%= locale.footer?.copied || '已复制' %>';
          setTimeout(function() { btn.textContent = orig; }, 1500);
        }).catch(function() {
          btn.textContent = '<%= locale.footer?.copy_failed || '复制失败' %>';
          setTimeout(function() { btn.textContent = '<%= locale.footer?.copied || '已复制' %>'; }, 1500);
        });
      });
    } catch(e) {}
    <% } %>

    <% if (config.CB_SHRINK) { %>
    try {
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.shrink-btn');
        if (!btn) return;
        var fig = btn.closest('.highlight');
        if (!fig) return;
        var pre = fig.querySelector('pre.code-wrap');
        if (!pre) return;
        pre.classList.toggle('code-shrink');
        pre.classList.toggle('code-expanded');
        if (pre.classList.contains('code-expanded')) {
          btn.textContent = '<%= locale.footer?.fold || '折叠' %>';
        } else {
          btn.textContent = '<%= locale.footer?.expand || '展开' %>';
        }
      });
    } catch(e) {}
    <% } %>

    <% if (config.CB_FULLPAGE) { %>
    try {
      var fullpageState = { fig: null, backdrop: null, dragMoved: false };

      function closeFullpage() {
        var st = fullpageState;
        if (!st.fig) return;
        st.fig.remove();
        document.body.classList.remove('code-fullpage-active');
        if (st.backdrop && st.backdrop.parentNode) {
          st.backdrop.parentNode.removeChild(st.backdrop);
        }
        st.backdrop = null;
        st.fig = null;
      }

      document.addEventListener('click', function(e) {
        if (fullpageState.dragMoved) return;
        var btn = e.target.closest('.fullpage-btn');
        if (!btn) return;
        var fig = btn.closest('.highlight');
        if (!fig) return;
        var st = fullpageState;

        if (fig.classList.contains('code-fullpage')) {
          closeFullpage();
          return;
        }

        st.fig = fig.cloneNode(true);
        st.fig.classList.add('code-fullpage');
        st.fig.style.background = '#e1e4e8';
        st.fig.style.setProperty('--shiki-light-bg', '#e1e4e8');
        st.fig.style.setProperty('--shiki-dark-bg', '#e1e4e8');

        var bd = document.createElement('div');
        bd.className = 'fullpage-backdrop';
        document.body.appendChild(bd);
        st.backdrop = bd;

        document.body.appendChild(st.fig);
        document.body.classList.add('code-fullpage-active');

        var icon = st.fig.querySelector('.fullpage-btn i');
        if (icon) icon.className = 'fas fa-compress';
      });

      (function() {
        var dragState = null;
        document.addEventListener('mousedown', function(e) {
          var tools = e.target.closest('.code-fullpage .highlight-tools');
          if (!tools) return;
          var fig = tools.closest('.highlight');
          if (!fig || !fig.classList.contains('code-fullpage')) return;
          e.preventDefault();
          var rect = fig.getBoundingClientRect();
          fullpageState.dragMoved = false;
          dragState = { fig: fig, startX: e.clientX, startY: e.clientY, origLeft: rect.left, origTop: rect.top };
        });
        document.addEventListener('mousemove', function(e) {
          if (!dragState) return;
          var dx = e.clientX - dragState.startX;
          var dy = e.clientY - dragState.startY;
          if (Math.abs(dx) > 3 || Math.abs(dy) > 3) fullpageState.dragMoved = true;
          dragState.fig.style.setProperty('transform', 'none', 'important');
          dragState.fig.style.setProperty('left', (dragState.origLeft + dx) + 'px', 'important');
          dragState.fig.style.setProperty('top', (dragState.origTop + dy) + 'px', 'important');
        });
        document.addEventListener('mouseup', function() {
          dragState = null;
          setTimeout(function() { fullpageState.dragMoved = false; }, 100);
        });
      })();

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeFullpage();
      });
    } catch(e) {}
    <% } %>

    /* Right-side buttons */
    try {
      document.getElementById('rightside-config').addEventListener('click', function() {
        document.getElementById('rightside-config-hide').classList.toggle('open');
      });
    } catch(e) {}

    <% if (config.DARKMODE_ENABLE && config.DARKMODE_BUTTON) { %>
    try {
      document.getElementById('darkmode').addEventListener('click', function() {
        var c = document.documentElement.getAttribute('data-theme');
        var n = c === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', n);
        localStorage.setItem('theme', n);
      });
    } catch(e) {}
    <% } %>

    try {
      document.getElementById('hide-aside-btn').addEventListener('click', function() {
        var layout = document.querySelector('.layout');
        if (layout) layout.classList.toggle('hide-aside');
        var hidden = layout ? layout.classList.contains('hide-aside') : false;
        localStorage.setItem('aside-status', hidden ? 'hide' : 'show');
      });
    } catch(e) {}

    try {
      var asideStatus = localStorage.getItem('aside-status');
      if (asideStatus === 'hide') {
        var layout = document.querySelector('.layout');
        if (layout) layout.classList.add('hide-aside');
      }
    } catch(e) {}

    /* Toggle menu (mobile sidebar) */
    try {
      var toggleMenu = document.getElementById('toggle-menu');
      var sidebar = document.getElementById('sidebar');
      var menuMask = document.getElementById('menu-mask');
      if (toggleMenu && sidebar && menuMask) {
        toggleMenu.addEventListener('click', function() {
          sidebar.classList.toggle('open');
          menuMask.classList.toggle('open');
        });
        menuMask.addEventListener('click', function() {
          sidebar.classList.remove('open');
          menuMask.classList.remove('open');
        });
      }
    } catch(e) {}

    /* Dropdown menus on mobile sidebar */
    try {
      document.querySelectorAll('#sidebar-menus .menus_item > .site-page.group').forEach(function(el) {
        el.addEventListener('click', function(e) {
          e.preventDefault();
          var child = this.nextElementSibling;
          if (child) {
            child.style.display = child.style.display === 'block' ? 'none' : 'block';
          }
        });
      });
    } catch(e) {}

    /* Scroll-down click goes to content */
    try {
      var sd = document.getElementById('scroll-down');
      if (sd) sd.addEventListener('click', function() {
        var target = document.getElementById('content-inner');
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    } catch(e) {}

    /* Nav scroll effect */
    try {
      var nav = document.getElementById('nav');
      if (nav) {
        <% if (config.NAV_FIXED) { %>
        nav.classList.add('fixed');
        <% } else { %>
        window.addEventListener('scroll', function() {
          if (window.scrollY > <%= config.NAV_SCROLL_THRESHOLD || 60 %>) {
            nav.classList.add('fixed');
          } else {
            nav.classList.remove('fixed');
          }
        });
        <% } %>
      }
    } catch(e) {}

    /* 卡片入场动画 (IntersectionObserver + transition) */
    try {
      var animItems = document.querySelectorAll('.recent-post-item, .card-widget, .tag-filter-bar, .empty-state');

      animItems.forEach(function(el) {
        el.classList.remove('reveal');
        el.style.animation = 'none';
        el.style.opacity = '0';
      });

      function setInitialState(el, index, isCard) {
        el.style.transition = 'none';
        if (isCard) {
          el.style.transform = 'translateX(40px)';
        } else {
          el.style.transform = 'translateY(30px)';
        }
        el.style.transitionDelay = (index * 0.12) + 's';
      }

      var articleIndex = 0;
      var widgetIndex = 0;
      var otherIndex = 0;

      animItems.forEach(function(el) {
        var isCard = el.classList.contains('recent-post-item');
        var isWidget = el.classList.contains('card-widget');
        var delay = 0;
        if (isCard) { delay = articleIndex; articleIndex++; }
        else if (isWidget) { delay = widgetIndex; widgetIndex++; }
        else { delay = otherIndex; otherIndex++; }
        setInitialState(el, delay, isCard);
      });

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var el = entry.target;
            el.style.transition = 'opacity 0.6s ease-out, transform 0.6s ease-out';
            el.style.opacity = '1';
            el.style.transform = 'translate(0, 0)';
            el.addEventListener('transitionend', function handler() {
              el.style.transition = '';
              el.style.opacity = '';
              el.style.transform = '';
              el.style.transitionDelay = '';
              el.classList.add('card-animated');
              el.removeEventListener('transitionend', handler);
            });
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.05 });

      animItems.forEach(function(el) { observer.observe(el); });
    } catch(e) {}

<% if (config.PWA_ENABLE) { %>
    try {
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('<%= basePath %>/sw.js');
      }
    } catch(e) {}
    <% } %>
  </script>
  
  <script src="<%= basePath %>/js/background.js" defer></script>

  <div id="font-settings-overlay" class="settings-overlay">
    <div class="settings-dialog">
      <div class="settings-header">
        <span class="settings-title"><i class="fas fa-font"></i> <%= locale.footer?.font_settings || '字体设置' %></span>
        <button class="settings-close"><i class="fas fa-times"></i></button>
      </div>
      <div class="settings-body">
        <div class="settings-group">
          <label class="settings-label"><%= locale.footer?.font_size || '字体大小' %></label>
          <div class="settings-options">
            <button class="settings-opt" data-fontsize="14"><%= locale.footer?.font_small || '小' %></button>
            <button class="settings-opt active" data-fontsize="16"><%= locale.footer?.font_medium || '中' %></button>
            <button class="settings-opt" data-fontsize="18"><%= locale.footer?.font_large || '大' %></button>
          </div>
        </div>

        <div class="settings-group">
          <label class="settings-label"><%= locale.footer?.reading_font || '阅读字体' %></label>
          <div class="settings-options">
            <button class="settings-opt active" data-bodyfont="">网站默认</button>
            <button class="settings-opt" data-bodyfont="unset">浏览器默认</button>
          </div>
          <div style="display:flex;gap:6px">
            <input class="settings-input" id="font-body-input" type="text" placeholder="<%= locale.footer?.font_custom_hint || '或输入自定义字体...' %>" style="flex:1">
            <button class="settings-scan-btn" data-target="body"><i class="fas fa-search"></i></button>
          </div>
          <div class="font-local-list" id="font-body-list"></div>
        </div>

        <div class="settings-group">
          <label class="settings-label"><%= locale.footer?.code_font || '代码字体' %></label>
          <div class="settings-options">
            <button class="settings-opt active" data-codefont="">网站默认</button>
            <button class="settings-opt" data-codefont="unset">浏览器默认</button>
          </div>
          <div style="display:flex;gap:6px">
            <input class="settings-input" id="font-code-input" type="text" placeholder="<%= locale.footer?.font_custom_hint || '或输入自定义字体...' %>" style="flex:1">
            <button class="settings-scan-btn" data-target="code"><i class="fas fa-search"></i></button>
          </div>
          <div class="font-local-list" id="font-code-list" style="display:none"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
  try {
    (function() {
      var FONT_KEY = 'blog_font_settings';
      var defaults = { fontSize: null, bodyFont: '', codeFont: '' };
      var saved;
      try { saved = JSON.parse(localStorage.getItem(FONT_KEY)); } catch(e) {}
      var settings = saved || defaults;

      function quoteFont(v) {
        if (!v || v === 'unset') return v;
        if (v.indexOf(',') !== -1 || v.indexOf("'") !== -1 || v.indexOf('"') !== -1) return v;
        return "'" + v + "'";
      }

      function applySettings(s, persist) {
        if (persist !== false) {
          try { localStorage.setItem(FONT_KEY, JSON.stringify(s)); } catch(e) {}
        }
        var d = document.documentElement;
        if (s.fontSize != null) d.style.setProperty('--font-size-global', s.fontSize + 'px');
        else d.style.removeProperty('--font-size-global');
        if (s.bodyFont === 'unset') d.style.removeProperty('--font-body');
        else if (s.bodyFont) d.style.setProperty('--font-body', quoteFont(s.bodyFont));
        else d.style.removeProperty('--font-body');
        if (s.codeFont === 'unset') d.style.removeProperty('--font-code');
        else if (s.codeFont) d.style.setProperty('--font-code', quoteFont(s.codeFont));
        else d.style.removeProperty('--font-code');
        // Update CSS style tag so ALL elements (including dynamic ones) get the font
        var cs = document.getElementById('__code_font_style');
        if (!cs) {
          cs = document.createElement('style');
          cs.id = '__code_font_style';
          document.head.appendChild(cs);
        }
        if (s.codeFont && s.codeFont !== 'unset') {
          var fn = s.codeFont.replace(/"/g, '\\"');
          cs.textContent = '@font-face{font-family:"' + fn + '";src:local("' + fn + '")}code,pre,.editor-gutter,#editor-input,textarea,.code-wrap,.highlight,.hljs,.font-local-item{font-family:"' + fn + '",monospace!important}';
          var gl = document.getElementById('__code_font_gf');
          if (!gl) { gl = document.createElement('link'); gl.rel = 'stylesheet'; gl.id = '__code_font_gf'; document.head.appendChild(gl); }
          gl.href = 'https://fonts.googleapis.com/css2?family=' + encodeURIComponent(s.codeFont) + ':wght@300;400;500;600;700&display=swap';
        } else {
          cs.textContent = '';
          var glRm = document.getElementById('__code_font_gf'); if (glRm) glRm.remove();
        }
        // Also apply direct DOM for immediate visual effect
        if (s.codeFont && s.codeFont !== 'unset') {
          var targets = document.querySelectorAll('code, pre, .editor-gutter, #editor-input, textarea, .gutter, .code-wrap, .highlight, .hljs, .font-local-item');
          for (var i = 0; i < targets.length; i++) {
            targets[i].style.setProperty('font-family', '"' + s.codeFont + '",monospace', 'important');
          }
        }
        if (s.bodyFont && s.bodyFont !== 'unset') {
          var bs = document.getElementById('__body_font_style');
          if (!bs) {
            bs = document.createElement('style');
            bs.id = '__body_font_style';
            document.head.appendChild(bs);
          }
          var fnB = s.bodyFont.replace(/"/g, '\\"');
          bs.textContent = '@font-face{font-family:"' + fnB + '";src:local("' + fnB + '")}body,.post-content,.content{font-family:"' + fnB + '",serif!important}';
          var bl = document.getElementById('__body_font_gf');
          if (!bl) { bl = document.createElement('link'); bl.rel = 'stylesheet'; bl.id = '__body_font_gf'; document.head.appendChild(bl); }
          bl.href = 'https://fonts.googleapis.com/css2?family=' + encodeURIComponent(s.bodyFont) + ':wght@300;400;500;600;700&display=swap';
        } else {
          var bs = document.getElementById('__body_font_style');
          if (bs) bs.textContent = '';
          var blRm = document.getElementById('__body_font_gf'); if (blRm) blRm.remove();
        }
        var bi = document.getElementById('font-body-input');
        var ci = document.getElementById('font-code-input');
        if (bi && bi !== document.activeElement) bi.value = s.bodyFont === 'unset' ? '' : s.bodyFont;
        if (ci && ci !== document.activeElement) ci.value = s.codeFont === 'unset' ? '' : s.codeFont;
        updatePresetActive(s);
      }

      function updatePresetActive(s) {
        var ov = document.getElementById('font-settings-overlay');
        if (!ov) return;
        ov.querySelectorAll('.settings-group').forEach(function(group) {
          var bBody = group.querySelector('[data-bodyfont]');
          var bCode = group.querySelector('[data-codefont]');
          if (!bBody && !bCode) return;
          group.querySelectorAll('.settings-opt').forEach(function(b) { b.classList.remove('active'); });
          if (bBody) {
            var val = s.bodyFont || '';
            group.querySelectorAll('[data-bodyfont]').forEach(function(b) {
              if (b.getAttribute('data-bodyfont') === val) b.classList.add('active');
            });
          }
          if (bCode) {
            var val = s.codeFont || '';
            group.querySelectorAll('[data-codefont]').forEach(function(b) {
              if (b.getAttribute('data-codefont') === val) b.classList.add('active');
            });
          }
        });
      }

      function syncUI() {
        var s;
        try { s = JSON.parse(localStorage.getItem(FONT_KEY)); } catch(e) {}
        if (!s) s = defaults;
        settings = s;
        applySettings(s, false);
        var bi = document.getElementById('font-body-input');
        var ci = document.getElementById('font-code-input');
        if (bi) bi.value = s.bodyFont === 'unset' ? '' : s.bodyFont;
        if (ci) ci.value = s.codeFont === 'unset' ? '' : s.codeFont;
      }

      var overlay = document.getElementById('font-settings-overlay');
      var openBtn = document.getElementById('font-settings-btn');
      var closeBtn = overlay ? overlay.querySelector('.settings-close') : null;

      syncUI();
      if (openBtn && overlay) {
        openBtn.addEventListener('click', function() {
          syncUI();
          overlay.style.display = 'flex';
        });
      }
      if (closeBtn && overlay) {
        closeBtn.addEventListener('click', function() { overlay.style.display = 'none'; });
      }

      var bodyInput = document.getElementById('font-body-input');
      var codeInput = document.getElementById('font-code-input');
      if (bodyInput) {
        bodyInput.value = settings.bodyFont === 'unset' ? '' : settings.bodyFont;
        bodyInput.addEventListener('input', function() {
          settings.bodyFont = this.value.trim();
          settings.bodyFontMode = 'custom';
          applySettings(settings);
        });
      }
      if (codeInput) {
        codeInput.value = settings.codeFont === 'unset' ? '' : settings.codeFont;
        codeInput.addEventListener('input', function() {
          settings.codeFont = this.value.trim();
          settings.codeFontMode = 'custom';
          applySettings(settings);
        });
      }

      function pickFont(target, value) {
        if (target === 'body') {
          settings.bodyFont = value;
          applySettings(settings);
          if (bodyInput) bodyInput.value = value === 'unset' ? '' : value;
        } else {
          settings.codeFont = value;
          applySettings(settings);
          if (codeInput) codeInput.value = value === 'unset' ? '' : value;
        }
      }

      overlay.addEventListener('click', function(e) {
        var btn = e.target.closest('.settings-opt');
        if (!btn) return;
        var group = btn.closest('.settings-group');
        group.querySelectorAll('.settings-opt').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var fs = btn.getAttribute('data-fontsize');
        var bf = btn.getAttribute('data-bodyfont');
        var cf = btn.getAttribute('data-codefont');
        if (fs) { settings.fontSize = parseInt(fs); applySettings(settings); }
        if (bf !== null) { pickFont('body', bf); }
        if (cf !== null) { pickFont('code', cf); }
      });

      var _allFonts = {};
      function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

      var _fallbackFontMap = {
        'Microsoft YaHei': '微软雅黑', 'SimSun': '宋体', 'SimHei': '黑体',
        'FangSong': '仿宋', 'KaiTi': '楷体', 'DengXian': '等线',
        'NSimSun': '新宋体', 'YouYuan': '幼圆', 'LiSu': '隶书',
        'STXihei': '华文细黑', 'STKaiti': '华文楷体', 'STSong': '华文宋体',
        'STFangsong': '华文仿宋', 'STHeiti': '华文黑体', 'STLiti': '华文隶书',
        'PMingLiU': '新细明体', 'MingLiU': '细明体', 'DFKai-SB': '标楷体',
        'PMingLiU-ExtB': '细明体-ExtB', 'MingLiU-ExtB': '细明体-ExtB',
        'Simsun (PMingLiU)': '宋体 (新细明体)', 'FangSong_GB2312': '仿宋_GB2312',
        'Kaiti_GB2312': '楷体_GB2312', 'Stkaiti': '华文楷体',
        'Source Han Sans CN': '思源黑体', 'Source Han Serif CN': '思源宋体',
        'Noto Sans CJK SC': 'Noto Sans CJK 简体', 'Noto Sans CJK TC': 'Noto Sans CJK 繁体',
        'Noto Serif CJK SC': 'Noto Serif CJK 简体', 'Noto Serif CJK TC': 'Noto Serif CJK 繁体',
        'PingFang SC': '苹方简体', 'PingFang TC': '苹方繁体', 'PingFang HK': '苹方港版',
        'Hiragino Sans GB': '冬青黑体', 'STXingkai': '华文行楷',
        'AR PL UMing CN': '文鼎PL细上海宋', 'AR PL UKai CN': '文鼎PL中楷',
        'WenQuanYi Micro Hei': '文泉驿微米黑', 'WenQuanYi Zen Hei': '文泉驿正黑',
        'Droid Sans Fallback': 'Droid Sans 回退字体',
        'Microsoft YaHei Light': '微软雅黑 细体', 'Microsoft YaHei UI': '微软雅黑 UI',
        'Microsoft YaHei UI Light': '微软雅黑 UI 细体', 'SimSun-ExtB': '宋体-ExtB',
        'Kaiti SC': '华文楷体 SC', 'Songti SC': '华文宋体 SC', 'Heiti SC': '华文黑体 SC',
        'Lantinghei SC': '华文兰亭黑 SC', 'STLantinghei SC': '华文兰亭黑',
        'STLantinghei SC Light': '华文兰亭黑 细体'
      };

      var _zhFontMapLoaded = null;
      function loadZhFontMap() {
        if (_zhFontMapLoaded) return _zhFontMapLoaded;
        _zhFontMapLoaded = (window._zhFontMapCache ? Promise.resolve(window._zhFontMapCache) : fetch('https://cdn.jsdelivr.net/gh/Moonvy/FontMetaDB@master/data/fontFamilyNameMap.zh.json').then(function(r) { if (!r.ok) throw new Error(r.status); return r.json(); })).then(function(data) {
          if (!data || typeof data !== 'object') return _fallbackFontMap;
          var merged = {};
          for (var k in _fallbackFontMap) merged[k] = _fallbackFontMap[k];
          for (var k in data) if (typeof data[k] === 'string' && data[k]) merged[k] = data[k];
          window._zhFontMapCache = merged;
          return merged;
        }).catch(function() {
          window._zhFontMapCache = _fallbackFontMap;
          return _fallbackFontMap;
        });
        return _zhFontMapLoaded;
      }

      function getDisplayName(engName, map) {
        return map && map[engName] ? engName + ' (' + map[engName] + ')' : engName;
      }
      function getSearchText(engName, map) {
        var zh = map && map[engName] ? map[engName] : '';
        return (engName + ' ' + zh).toLowerCase();
      }

      function showLocalFonts(target) {
        var list = document.getElementById('font-' + target + '-list');
        if (!list) return;
        if (list.dataset.loaded) { list.style.display = list.style.display === 'none' ? 'block' : 'none'; return; }
        list.style.display = 'block';
        list.dataset.loaded = '1';
        list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体（支持中文名）..." id="font-search-' + target + '"><div style="padding:8px 0;text-align:center;color:var(--text-muted);font-size:0.85em">正在加载字体库...</div>';
        loadZhFontMap().then(function(zhFontMap) {
          list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体（支持中文名）..." id="font-search-' + target + '"><div style="padding:8px 0;text-align:center;color:var(--text-muted);font-size:0.85em">扫描中...</div>';
          var doScan = function(fonts) {
            var names = [...new Set(fonts.map(function(f) { return f.family; }))].filter(function(n) { return n && n.trim(); }).sort(function(a,b) { return a.localeCompare(b, 'en'); });
            _allFonts[target] = names;
            if (names.length === 0) {
              list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体（支持中文名）..." id="font-search-' + target + '"><div style="padding:8px 0;text-align:center;color:var(--text-muted);font-size:0.85em">未检测到可用字体</div>';
              return;
            }
            list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体（支持中文名）..." id="font-search-' + target + '">';
            names.forEach(function(n) {
              var el = document.createElement('div');
              el.className = 'font-local-item';
              el.setAttribute('data-target', target);
              el.setAttribute('data-font', n);
              el.setAttribute('data-search', getSearchText(n, zhFontMap));
              el.textContent = getDisplayName(n, zhFontMap);
              list.appendChild(el);
            });
            document.getElementById('font-search-' + target).addEventListener('input', function() {
              var q = this.value.toLowerCase();
              var items = list.querySelectorAll('.font-local-item');
              items.forEach(function(el) {
                var searchText = el.getAttribute('data-search');
                if (searchText.indexOf(q) !== -1) el.style.display = '';
                else el.style.display = 'none';
              });
            });
          };
          if ('queryLocalFonts' in window) {
            window.queryLocalFonts().then(doScan).catch(function() {
              list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体..." id="font-search-' + target + '"><div style="padding:8px 0;text-align:center;color:var(--text-muted);font-size:0.85em">权限被拒绝或浏览器不支持</div>';
            });
          } else {
            list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体..." id="font-search-' + target + '"><div style="padding:8px 0;text-align:center;color:var(--text-muted);font-size:0.85em">当前浏览器不支持扫描本地字体</div>';
          }
        });
      }

      overlay.addEventListener('click', function(e) {
        var scanBtn = e.target.closest('.settings-scan-btn');
        if (scanBtn) { showLocalFonts(scanBtn.getAttribute('data-target')); return; }
        var item = e.target.closest('.font-local-item');
        if (item) {
          var target = item.getAttribute('data-target');
          var font = item.getAttribute('data-font');
          pickFont(target, font);
          var input = document.getElementById('font-' + target + '-input');
          if (input) input.value = font;
          document.getElementById('font-' + target + '-list').style.display = 'none';
        }
      });
    })();
  } catch(e) { console.error(e); }
  </script>

  <% if (config.SEARCH_ENABLE) { %>
  <div id="search-mask" class="search-mask"></div>
  <div id="local-search" class="local-search">
    <div class="search-dialog">
      <nav class="search-nav">
        <span class="search-dialog-title"><i class="fas fa-search"></i> <%= locale.search?.title || '搜索' %></span>
        <button class="search-close-button"><i class="fas fa-times"></i></button>
      </nav>
      <div class="local-search-input">
        <input type="text" id="searchInput" placeholder="<%= config.SEARCH_PLACEHOLDER %>" autocomplete="off">
      </div>
      <hr>
      <div id="local-search-results" class="search-result-list"></div>
      <div id="local-search-stats" class="search-stats"></div>
    </div>
  </div>
  <script src="<%= config.CDN.FUSE_JS %>"></script>
  <script>
    (function() {
      var fuse = null;
      var overlay = document.getElementById('local-search');
      var mask = document.getElementById('search-mask');
      var input = document.getElementById('searchInput');
      var closeBtn = document.querySelector('.search-close-button');
      var searchBtn = document.getElementById('searchBtn');
      var resultsEl = document.getElementById('local-search-results');
      var statsEl = document.getElementById('local-search-stats');
      if (!overlay || !input) return;

      function loadIndex(cb) {
        if (fuse) { cb(); return; }
        fetch('<%= basePath %>/search.json').then(function(r) { return r.json(); }).then(function(d) {
          fuse = new Fuse(d, { keys: ['title', 'content', 'tags'], threshold: <%= config.SEARCH_THRESHOLD %>, includeScore: true });
          cb();
        })['catch'](function() {});
      }

      function doSearch(q) {
        if (!q || q.length < <%= config.SEARCH_MIN_QUERY_LENGTH %>) { resultsEl.innerHTML = ''; statsEl.textContent = ''; return; }
        loadIndex(function() {
          var res = fuse.search(q).slice(0, <%= config.SEARCH_MAX_RESULTS %>).map(function(m) { return m.item; });
          if (res.length === 0) {
            resultsEl.innerHTML = '<div class="search-no-result"><%= locale.search?.no_results || '未找到相关内容' %></div>';
            statsEl.textContent = '0<%= locale.search?.result_count_suffix || ' 个结果' %>';
          } else {
            resultsEl.innerHTML = '<ol class="search-result-list">' + res.map(function(r) {
              return '<li class="search-result-item"><a href="<%= basePath %>' + r.url + '" class="search-result-item-link">' +
                '<span class="search-result-title">' + r.title + '</span>' +
                '<span class="search-result-excerpt">' + r.content.substring(0, <%= config.SEARCH_EXCERPT_LENGTH %>) + '</span></a></li>';
            }).join('') + '</ol>';
            statsEl.textContent = res.length + '<%= locale.search?.result_count_suffix || ' 个结果' %>';
          }
        });
      }

      function openSearch() {
        overlay.style.display = 'block';
        mask.style.display = 'block';
        setTimeout(function() { input.focus(); }, 100);
      }

      function closeSearch() {
        overlay.style.display = 'none';
        mask.style.display = 'none';
        input.value = '';
        resultsEl.innerHTML = '';
        statsEl.textContent = '';
      }

      if (searchBtn) searchBtn.addEventListener('click', openSearch);
      if (closeBtn) closeBtn.addEventListener('click', closeSearch);
      if (mask) mask.addEventListener('click', closeSearch);

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && overlay.style.display === 'block') closeSearch();
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
        if (e.key === '/' && !e.ctrlKey && !e.metaKey && !e.target.closest('input,textarea')) { e.preventDefault(); openSearch(); }
      });

      input.addEventListener('input', function() {
        clearTimeout(this.searchTimer);
        var q = this.value.trim();
        this.searchTimer = setTimeout(function() { doSearch(q); }, <%= config.SEARCH_DEBOUNCE_MS %>);
      });
      input.addEventListener('keydown', function(e) { if (e.key === 'Enter') doSearch(this.value.trim()); });
    })();
  </script>
  <% } %>
  <script>
  try {
    (function() {
      var MAX_RETRY = 2;
      var covers = <%- JSON.stringify(Array.isArray(config.DEFAULT_COVER) ? config.DEFAULT_COVER : [config.DEFAULT_COVER || config.FALLBACK_COVER || 'https://t.alcy.cc/fj']) %>;
      function retryImg(img) {
        var retries = parseInt(img.getAttribute('data-retry') || '0');
        if (retries >= MAX_RETRY || !img.getAttribute('data-origin-src')) return;
        img.setAttribute('data-retry', retries + 1);
        var url = covers[Math.floor(Math.random() * covers.length)];
        var sep = url.includes('?') ? '&' : '?';
        img.src = url + sep + 'v=' + Date.now() + '_' + retries;
      }
      document.addEventListener('error', function(e) {
        if (e.target && e.target.tagName === 'IMG') {
          var img = e.target;
          if (!img.getAttribute('data-origin-src')) {
            img.setAttribute('data-origin-src', img.src);
          }
          setTimeout(function() { retryImg(img); }, 500 * (parseInt(img.getAttribute('data-retry') || '0') + 1));
        }
      }, true);
    })();
  } catch(e) {}
  </script>
</body>
</html>