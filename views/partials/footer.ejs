  </div><!-- #body-wrap -->

  <footer id="footer">
    <div id="footer-wrap">
      <% if (config.FOOTER_OWNER_ENABLE) { %>
      <div class="copyright">&copy;<%= config.FOOTER_OWNER_SINCE %> <%= locale.footer?.powered_by_label || 'By' %> <%= config.BLOG_AUTHOR %></div>
      <% } %>
      <% if (config.FOOTER_COPYRIGHT) { %>
      <div class="framework-info">
        <span><%= locale.footer?.framework_label || '框架' %> </span><a target="_blank" rel="noopener" href="https://expressjs.com">Express</a>
        <span class="footer-separator">|</span>
        <span><%= locale.footer?.theme_label || '主题' %> </span><a target="_blank" rel="noopener" href="https://github.com/jerryc127/hexo-theme-butterfly">Butterfly</a>
      </div>
      <% } %>
      <% if (config.FOOTER_CUSTOM_TEXT) { %>
        <div style="margin-top:8px;font-size:0.82em;color:var(--text-muted)"><%= config.FOOTER_CUSTOM_TEXT %></div>
      <% } %>
    </div>
  </footer>

  <div id="rightside">
    <div id="rightside-config-hide">
      <button id="darkmode" type="button" title="<%= locale.footer?.day_night_toggle || '日间和夜间模式切换' %>"><i class="fas fa-adjust"></i></button>
      <button id="hide-aside-btn" type="button" title="<%= locale.footer?.column_toggle || '单栏和双栏切换' %>"><i class="fas fa-arrows-alt-h"></i></button>
    <button id="font-settings-btn" type="button" title="<%= locale.footer?.font_settings || '字体设置' %>"><i class="fas fa-font"></i></button>
    </div>
    <div id="rightside-config-show">
      <button id="rightside-config" type="button" title="<%= locale.footer?.settings || '设置' %>"><i class="fas fa-cog fa-spin"></i></button>
      <button id="go-up" type="button" title="<%= locale.footer?.back_to_top || '回到顶部' %>"><span class="scroll-percent">0</span><i class="fas fa-arrow-up"></i></button>
    </div>
  </div>

  <script src="<%= basePath %>/assets/main.js?v=<%= typeof cssVersion !== 'undefined' ? cssVersion : '1' %>"></script>
  <script>
    try {
      var h = document.documentElement;
      <% if (config.DARKMODE_ENABLE) { %>
      var s = localStorage.getItem('theme');
      if (s) { h.setAttribute('data-theme', s); } else {
        <% if (config.DARKMODE_AUTO === 1) { %>
        if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) h.setAttribute('data-theme', 'dark');
        <% } else if (config.DARKMODE_AUTO === 2) { %>
        var hr = (new Date()).getHours(); var start = <%= config.DARKMODE_START %>; var end = <%= config.DARKMODE_END %>;
        if (start > end) { if (hr >= start || hr < end) h.setAttribute('data-theme', 'dark'); }
        else { if (hr >= start && hr < end) h.setAttribute('data-theme', 'dark'); }
        <% } %>
      }
      <% } %>
      var t = document.getElementById('themeToggle');
      if (t) {
        var i = t.querySelector('i');
        if (h.getAttribute('data-theme') === 'dark') i.className = 'fas fa-sun';
        t.addEventListener('click', function() {
          var c = h.getAttribute('data-theme');
          var n = c === 'dark' ? 'light' : 'dark';
          h.setAttribute('data-theme', n);
          localStorage.setItem('theme', n);
          i.className = n === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
        });
      }
    } catch(e) {}

    try {
      var rt = document.querySelector('.runtime-days');
      if (rt) {
        var startDate = rt.getAttribute('data-start');
        if (startDate) {
          var start = new Date(startDate);
          var now = new Date();
          var days = Math.floor((now - start) / (1000 * 60 * 60 * 24));
          rt.textContent = days + ' 天';
        }
      }
    } catch(e) {}

    try {
      var lut = document.querySelector('.last-update-time');
      if (lut) {
        var timeStr = lut.getAttribute('data-time');
        if (timeStr) {
          var updateDate = new Date(timeStr);
          var now = new Date();
          var diffMs = now - updateDate;
          var diffMonths = Math.floor(diffMs / (1000 * 60 * 60 * 24 * 30));
          if (diffMonths < 1) {
            var diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
            lut.textContent = diffDays + ' 天前';
          } else if (diffMonths < 12) {
            lut.textContent = diffMonths + ' 个月前';
          } else {
            var diffYears = Math.floor(diffMonths / 12);
            lut.textContent = diffYears + ' 年前';
          }
        }
      }
    } catch(e) {}

    try {
      var today = new Date().toDateString();
      var lastVisit = localStorage.getItem('blog_last_visit');
      if (lastVisit !== today) {
        localStorage.setItem('blog_last_visit', today);
        fetch('<%= basePath %>/api/stats/visit', { method: 'POST' });
      }
    } catch(e) {}

    try {
      var postId = window.location.pathname.match(/\/posts\/(\d+)/);
      if (postId) {
        fetch('<%= basePath %>/api/stats/view/' + postId[1], { method: 'POST' });
      }
    } catch(e) {}

    try {
      document.getElementById('menuToggle').addEventListener('click', function() {
        document.getElementById('mobileMenu').classList.toggle('open');
      });
    } catch(e) {}

    try {
      window.addEventListener('scroll', function() {
        var bar = document.getElementById('progressBar');
        if (!bar) return;
        var h = document.documentElement.scrollHeight - window.innerHeight;
        var p = h > 0 ? (window.scrollY / h) * 100 : 0;
        bar.style.width = p + '%';
      });
    } catch(e) {}

    try {
      var goUp = document.getElementById('go-up');
      var scrollPercent = goUp ? goUp.querySelector('.scroll-percent') : null;
      if (goUp) {
        goUp.addEventListener('click', function() {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
      window.addEventListener('scroll', function() {
        var h = document.documentElement.scrollHeight - window.innerHeight;
        var p = h > 0 ? Math.round((window.scrollY / h) * 100) : 0;
        if (scrollPercent) scrollPercent.textContent = p;
      });
    } catch(e) {}

    try {
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.copy-btn');
        if (!btn) return;
        var fig = btn.closest('.highlight');
        var codeEl = fig.querySelector('pre.code-wrap code');
        if (!codeEl) return;
        var text = codeEl.textContent;
        navigator.clipboard.writeText(text).then(function() {
          var orig = btn.textContent;
          btn.textContent = '<%= locale.footer?.copied || '已复制' %>';
          setTimeout(function() { btn.textContent = orig; }, 1500);
        }).catch(function() {
          btn.textContent = '<%= locale.footer?.copy_failed || '复制失败' %>';
          setTimeout(function() { btn.textContent = '<%= locale.footer?.copied || '已复制' %>'; }, 1500);
        });
      });
    } catch(e) {}

    try {
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.shrink-btn');
        if (!btn) return;
        var fig = btn.closest('.highlight');
        if (!fig) return;
        var pre = fig.querySelector('pre.code-wrap');
        if (!pre) return;
        pre.classList.toggle('code-shrink');
        pre.classList.toggle('code-expanded');
        if (pre.classList.contains('code-expanded')) {
          btn.textContent = '<%= locale.footer?.fold || '折叠' %>';
        } else {
          btn.textContent = '<%= locale.footer?.expand || '展开' %>';
        }
      });
    } catch(e) {}

    try {
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.fullpage-btn');
        if (!btn) return;
        var fig = btn.closest('.highlight');
        if (!fig) return;
        fig.classList.toggle('code-fullpage');
        document.body.classList.toggle('code-fullpage-active', fig.classList.contains('code-fullpage'));
        var icon = fig.querySelector('.fullpage-btn i');
        if (icon) icon.className = fig.classList.contains('code-fullpage') ? 'fas fa-compress' : 'fas fa-expand';
      });
    } catch(e) {}

    /* Right-side buttons */
    try {
      document.getElementById('rightside-config').addEventListener('click', function() {
        document.getElementById('rightside-config-hide').classList.toggle('open');
      });
    } catch(e) {}

    try {
      document.getElementById('darkmode').addEventListener('click', function() {
        var c = document.documentElement.getAttribute('data-theme');
        var n = c === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', n);
        localStorage.setItem('theme', n);
      });
    } catch(e) {}

    try {
      document.getElementById('hide-aside-btn').addEventListener('click', function() {
        var layout = document.querySelector('.layout');
        if (layout) layout.classList.toggle('hide-aside');
        var hidden = layout ? layout.classList.contains('hide-aside') : false;
        localStorage.setItem('aside-status', hidden ? 'hide' : 'show');
      });
    } catch(e) {}

    try {
      var asideStatus = localStorage.getItem('aside-status');
      if (asideStatus === 'hide') {
        var layout = document.querySelector('.layout');
        if (layout) layout.classList.add('hide-aside');
      }
    } catch(e) {}

    /* Toggle menu (mobile sidebar) */
    try {
      var toggleMenu = document.getElementById('toggle-menu');
      var sidebar = document.getElementById('sidebar');
      var menuMask = document.getElementById('menu-mask');
      if (toggleMenu && sidebar && menuMask) {
        toggleMenu.addEventListener('click', function() {
          sidebar.classList.toggle('open');
          menuMask.classList.toggle('open');
        });
        menuMask.addEventListener('click', function() {
          sidebar.classList.remove('open');
          menuMask.classList.remove('open');
        });
      }
    } catch(e) {}

    /* Dropdown menus on mobile sidebar */
    try {
      document.querySelectorAll('#sidebar-menus .menus_item > .site-page.group').forEach(function(el) {
        el.addEventListener('click', function(e) {
          e.preventDefault();
          var child = this.nextElementSibling;
          if (child) {
            child.style.display = child.style.display === 'block' ? 'none' : 'block';
          }
        });
      });
    } catch(e) {}

    /* Scroll-down click goes to content */
    try {
      var sd = document.getElementById('scroll-down');
      if (sd) sd.addEventListener('click', function() {
        var target = document.getElementById('content-inner');
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    } catch(e) {}

    /* Nav scroll effect */
    try {
      var nav = document.getElementById('nav');
      if (nav) {
        window.addEventListener('scroll', function() {
          if (window.scrollY > 60) {
            nav.classList.add('fixed');
          } else {
            nav.classList.remove('fixed');
          }
        });
      }
    } catch(e) {}

<% if (config.PWA_ENABLE) { %>
    try {
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('<%= basePath %>/sw.js');
      }
    } catch(e) {}
    <% } %>
  </script>

  <div id="font-settings-overlay" class="settings-overlay">
    <div class="settings-dialog">
      <div class="settings-header">
        <span class="settings-title"><i class="fas fa-font"></i> <%= locale.footer?.font_settings || '字体设置' %></span>
        <button class="settings-close"><i class="fas fa-times"></i></button>
      </div>
      <div class="settings-body">
        <div class="settings-group">
          <label class="settings-label"><%= locale.footer?.font_size || '字体大小' %></label>
          <div class="settings-options">
            <button class="settings-opt" data-fontsize="14"><%= locale.footer?.font_small || '小' %></button>
            <button class="settings-opt active" data-fontsize="16"><%= locale.footer?.font_medium || '中' %></button>
            <button class="settings-opt" data-fontsize="18"><%= locale.footer?.font_large || '大' %></button>
          </div>
        </div>

        <div class="settings-group">
          <label class="settings-label"><%= locale.footer?.reading_font || '阅读字体' %></label>
          <div class="settings-options">
            <button class="settings-opt active" data-bodyfont="">网站默认</button>
            <button class="settings-opt" data-bodyfont="unset">浏览器默认</button>
          </div>
          <div style="display:flex;gap:6px">
            <input class="settings-input" id="font-body-input" type="text" placeholder="<%= locale.footer?.font_custom_hint || '或输入自定义字体...' %>" style="flex:1">
            <button class="settings-scan-btn" data-target="body"><i class="fas fa-search"></i></button>
          </div>
          <div class="font-local-list" id="font-body-list"></div>
        </div>

        <div class="settings-group">
          <label class="settings-label"><%= locale.footer?.code_font || '代码字体' %></label>
          <div class="settings-options">
            <button class="settings-opt active" data-codefont="">网站默认</button>
            <button class="settings-opt" data-codefont="unset">浏览器默认</button>
          </div>
          <div style="display:flex;gap:6px">
            <input class="settings-input" id="font-code-input" type="text" placeholder="<%= locale.footer?.font_custom_hint || '或输入自定义字体...' %>" style="flex:1">
            <button class="settings-scan-btn" data-target="code"><i class="fas fa-search"></i></button>
          </div>
          <div class="font-local-list" id="font-code-list" style="display:none"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
  try {
    (function() {
      var FONT_KEY = 'blog_font_settings';
      var defaults = { fontSize: 16, bodyFont: '', codeFont: '' };
      var saved;
      try { saved = JSON.parse(localStorage.getItem(FONT_KEY)); } catch(e) {}
      var settings = saved || defaults;

      function applySettings(s) {
        document.documentElement.style.setProperty('--font-size-global', s.fontSize + 'px');
        if (s.bodyFont === 'unset') document.documentElement.style.removeProperty('--font-body');
        else if (s.bodyFont) document.documentElement.style.setProperty('--font-body', s.bodyFont);
        else document.documentElement.style.removeProperty('--font-body');
        if (s.codeFont === 'unset') document.documentElement.style.removeProperty('--font-code');
        else if (s.codeFont) document.documentElement.style.setProperty('--font-code', s.codeFont);
        else document.documentElement.style.removeProperty('--font-code');
        try { localStorage.setItem(FONT_KEY, JSON.stringify(s)); } catch(e) {}
        var bi = document.getElementById('font-body-input');
        var ci = document.getElementById('font-code-input');
        if (bi && bi !== document.activeElement) bi.value = s.bodyFont === 'unset' ? '' : s.bodyFont;
        if (ci && ci !== document.activeElement) ci.value = s.codeFont === 'unset' ? '' : s.codeFont;
      }

      applySettings(settings);

      var overlay = document.getElementById('font-settings-overlay');
      var openBtn = document.getElementById('font-settings-btn');
      var closeBtn = overlay ? overlay.querySelector('.settings-close') : null;
      if (openBtn && overlay) {
        openBtn.addEventListener('click', function() { overlay.style.display = 'flex'; });
      }
      if (closeBtn && overlay) {
        closeBtn.addEventListener('click', function() { overlay.style.display = 'none'; });
      }

      var bodyInput = document.getElementById('font-body-input');
      var codeInput = document.getElementById('font-code-input');
      if (bodyInput) {
        bodyInput.value = settings.bodyFont === 'unset' ? '' : settings.bodyFont;
        bodyInput.addEventListener('input', function() {
          settings.bodyFont = this.value.trim();
          settings.bodyFontMode = 'custom';
          applySettings(settings);
        });
      }
      if (codeInput) {
        codeInput.value = settings.codeFont === 'unset' ? '' : settings.codeFont;
        codeInput.addEventListener('input', function() {
          settings.codeFont = this.value.trim();
          settings.codeFontMode = 'custom';
          applySettings(settings);
        });
      }

      function pickFont(target, value) {
        if (target === 'body') {
          settings.bodyFont = value;
          applySettings(settings);
          if (bodyInput) bodyInput.value = value === 'unset' ? '' : value;
        } else {
          settings.codeFont = value;
          applySettings(settings);
          if (codeInput) codeInput.value = value === 'unset' ? '' : value;
        }
      }

      overlay.addEventListener('click', function(e) {
        var btn = e.target.closest('.settings-opt');
        if (!btn) return;
        var group = btn.closest('.settings-group');
        group.querySelectorAll('.settings-opt').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var fs = btn.getAttribute('data-fontsize');
        var bf = btn.getAttribute('data-bodyfont');
        var cf = btn.getAttribute('data-codefont');
        if (fs) { settings.fontSize = parseInt(fs); applySettings(settings); }
        if (bf !== null) { pickFont('body', bf); }
        if (cf !== null) { pickFont('code', cf); }
      });

      var _allFonts = {};
      function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

      function showLocalFonts(target) {
        var list = document.getElementById('font-' + target + '-list');
        if (!list) return;
        if (list.dataset.loaded) { list.style.display = list.style.display === 'none' ? 'block' : 'none'; return; }
        list.style.display = 'block';
        list.dataset.loaded = '1';
        list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体..." id="font-search-' + target + '"><div style="padding:8px 0;text-align:center;color:var(--text-muted);font-size:0.85em">扫描中...</div>';
        var doScan = function(fonts) {
          var names = [...new Set(fonts.map(function(f) { return f.family; }))].filter(function(n) { return n && n.trim(); }).sort(function(a,b) { return a.localeCompare(b); });
          _allFonts[target] = names;
          if (names.length === 0) {
            list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体..." id="font-search-' + target + '"><div style="padding:8px 0;text-align:center;color:var(--text-muted);font-size:0.85em">未检测到可用字体</div>';
            return;
          }
          list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体..." id="font-search-' + target + '">';
          names.forEach(function(n) {
            var el = document.createElement('div');
            el.className = 'font-local-item';
            el.setAttribute('data-target', target);
            el.setAttribute('data-font', n);
            el.textContent = n;
            list.appendChild(el);
          });
          document.getElementById('font-search-' + target).addEventListener('input', function() {
            var q = this.value.toLowerCase();
            var items = list.querySelectorAll('.font-local-item');
            items.forEach(function(el) {
              if (el.textContent.toLowerCase().indexOf(q) !== -1) el.style.display = '';
              else el.style.display = 'none';
            });
          });
        };
        if ('queryLocalFonts' in window) {
          window.queryLocalFonts().then(doScan).catch(function() {
            list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体..." id="font-search-' + target + '"><div style="padding:8px 0;text-align:center;color:var(--text-muted);font-size:0.85em">权限被拒绝或浏览器不支持</div>';
          });
        } else {
          list.innerHTML = '<input class="font-local-search" type="text" placeholder="搜索字体..." id="font-search-' + target + '"><div style="padding:8px 0;text-align:center;color:var(--text-muted);font-size:0.85em">当前浏览器不支持扫描本地字体</div>';
        }
      }

      overlay.addEventListener('click', function(e) {
        var scanBtn = e.target.closest('.settings-scan-btn');
        if (scanBtn) { showLocalFonts(scanBtn.getAttribute('data-target')); return; }
        var item = e.target.closest('.font-local-item');
        if (item) {
          var target = item.getAttribute('data-target');
          var font = item.getAttribute('data-font');
          pickFont(target, font);
          var input = document.getElementById('font-' + target + '-input');
          if (input) input.value = font;
          document.getElementById('font-' + target + '-list').style.display = 'none';
        }
      });
    })();
  } catch(e) { console.error(e); }
  </script>

  <% if (config.SEARCH_ENABLE) { %>
  <div id="search-mask" class="search-mask"></div>
  <div id="local-search" class="local-search">
    <div class="search-dialog">
      <nav class="search-nav">
        <span class="search-dialog-title"><i class="fas fa-search"></i> <%= locale.search?.title || '搜索' %></span>
        <button class="search-close-button"><i class="fas fa-times"></i></button>
      </nav>
      <div class="local-search-input">
        <input type="text" id="searchInput" placeholder="<%= config.SEARCH_PLACEHOLDER %>" autocomplete="off">
      </div>
      <hr>
      <div id="local-search-results" class="search-result-list"></div>
      <div id="local-search-stats" class="search-stats"></div>
    </div>
  </div>
  <script src="<%= config.CDN.FUSE_JS %>"></script>
  <script>
    (function() {
      var fuse = null;
      var overlay = document.getElementById('local-search');
      var mask = document.getElementById('search-mask');
      var input = document.getElementById('searchInput');
      var closeBtn = document.querySelector('.search-close-button');
      var searchBtn = document.getElementById('searchBtn');
      var navSearchBtn = document.getElementById('navSearchBtn');
      var resultsEl = document.getElementById('local-search-results');
      var statsEl = document.getElementById('local-search-stats');
      if (!overlay || !input) return;

      function loadIndex(cb) {
        if (fuse) { cb(); return; }
        fetch('<%= basePath %>/search.json').then(function(r) { return r.json(); }).then(function(d) {
          fuse = new Fuse(d, { keys: ['title', 'content', 'tags'], threshold: <%= config.SEARCH_THRESHOLD %>, includeScore: true });
          cb();
        })['catch'](function() {});
      }

      function doSearch(q) {
        if (!q || q.length < <%= config.SEARCH_MIN_QUERY_LENGTH %>) { resultsEl.innerHTML = ''; statsEl.textContent = ''; return; }
        loadIndex(function() {
          var res = fuse.search(q).slice(0, <%= config.SEARCH_MAX_RESULTS %>).map(function(m) { return m.item; });
          if (res.length === 0) {
            resultsEl.innerHTML = '<div class="search-no-result"><%= locale.search?.no_results || '未找到相关内容' %></div>';
            statsEl.textContent = '0<%= locale.search?.result_count_suffix || ' 个结果' %>';
          } else {
            resultsEl.innerHTML = '<ol class="search-result-list">' + res.map(function(r) {
              return '<li class="search-result-item"><a href="<%= basePath %>' + r.url + '" class="search-result-item-link">' +
                '<span class="search-result-title">' + r.title + '</span>' +
                '<span class="search-result-excerpt">' + r.content.substring(0, <%= config.SEARCH_EXCERPT_LENGTH %>) + '</span></a></li>';
            }).join('') + '</ol>';
            statsEl.textContent = res.length + '<%= locale.search?.result_count_suffix || ' 个结果' %>';
          }
        });
      }

      function openSearch() {
        overlay.style.display = 'block';
        mask.style.display = 'block';
        setTimeout(function() { input.focus(); }, 100);
      }

      function closeSearch() {
        overlay.style.display = 'none';
        mask.style.display = 'none';
        input.value = '';
        resultsEl.innerHTML = '';
        statsEl.textContent = '';
      }

      if (searchBtn) searchBtn.addEventListener('click', openSearch);
      if (navSearchBtn) navSearchBtn.addEventListener('click', openSearch);
      if (closeBtn) closeBtn.addEventListener('click', closeSearch);
      if (mask) mask.addEventListener('click', closeSearch);

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && overlay.style.display === 'block') closeSearch();
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
        if (e.key === '/' && !e.ctrlKey && !e.metaKey && !e.target.closest('input,textarea')) { e.preventDefault(); openSearch(); }
      });

      input.addEventListener('input', function() {
        clearTimeout(this.searchTimer);
        var q = this.value.trim();
        this.searchTimer = setTimeout(function() { doSearch(q); }, <%= config.SEARCH_DEBOUNCE_MS %>);
      });
      input.addEventListener('keydown', function(e) { if (e.key === 'Enter') doSearch(this.value.trim()); });
    })();
  </script>
  <% } %>
</body>
</html>