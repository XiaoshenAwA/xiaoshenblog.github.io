<%- include('partials/header', { title: locale.friends?.title || '友链', subtitle: locale.friends?.subtitle || '各位大佬们的博客' }) %>

  <main class="layout<%= !config.ASIDE_ENABLE ? ' hide-aside' : '' %>" id="content-inner">
    <div id="friend">

      <% if (!friends || friends.length === 0) { %>
        <div class="empty-state reveal">
          <div class="empty-icon"><i class="fas fa-link"></i></div>
          <h3><%= locale.friends?.empty_title || '暂无友链' %></h3>
          <p><%= locale.friends?.empty_text || '在 config.yml 的 friend_links 中添加友链' %></p>
        </div>
      <% } else { %>
        <div class="friends-grid">
          <% friends.forEach(f => { %>
            <a href="<%= f.link %>" target="_blank" class="friend-card card reveal" rel="noopener">
              <div class="friend-avatar">
                <img src="<%= f.avatar || config.AVATAR_IMG || 'https://cdn.luogu.com.cn/upload/usericon/852112.png' %>" alt="<%= f.name %>" loading="lazy">
              </div>
              <div class="friend-info">
                <h3><%= f.name %></h3>
                <p><%= f.description || '' %></p>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="aside-content" id="aside-content">
      <%- include('partials/sidebar') %>
    </div>
  </main>

<%- include('partials/footer') %>