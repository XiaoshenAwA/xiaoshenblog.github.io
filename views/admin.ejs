<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>后台管理 | MyBlog</title>
  <link rel="stylesheet" href="<%= basePath %>/assets/main.css" onerror="this.onerror=null;this.href='<%= basePath %>/css/style.css'">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.17.0/dist/katex.min.css" crossorigin="anonymous">
  <link rel="stylesheet" href="<%= basePath %>/assets/admin.css">
  <style>
    .message-msg { margin-top: 10px; padding: 8px; border-radius: 4px; }
    .message-msg.success { color: #155724; background-color: #d4edda; border: 1px solid #c3e6cb; }
    .message-msg.error { color: #721c24; background-color: #f8d7da; border: 1px solid #f5c6cb; }
    .admin-header .btn-group { display: inline-flex; gap: 8px; align-items: center; }
  </style>
</head>
<body>
<div class="admin-page">
  <div class="admin-header">
    <h1><i class="fas fa-cog"></i> 后台管理</h1>
    <div>
      <span class="admin-user" id="user-email"></span>
      <div class="btn-group">
        <button class="btn btn-sm btn-outline" id="change-pw-btn" style="display:none">修改密码</button>
        <button class="btn btn-sm btn-outline" id="logout-btn" style="display:none">退出</button>
      </div>
    </div>
  </div>

  <div class="admin-view" id="view-login">
    <div class="login-box">
      <h2><i class="fas fa-lock"></i> 管理员登录</h2>
      <form id="login-form">
        <div class="form-group">
          <input type="email" id="login-email" placeholder="邮箱" required>
        </div>
        <div class="form-group">
          <input type="password" id="login-password" placeholder="密码" required>
        </div>
        <button type="submit" class="btn btn-primary">登录</button>
        <div class="error-msg" id="login-error"></div>
      </form>
    </div>
  </div>

  <div class="admin-view" id="view-posts">
    <div class="toolbar">
      <button class="btn btn-primary" id="new-post-btn"><i class="fas fa-plus"></i> 写新文章</button>
      <a href="<%= basePath %>/" class="btn btn-outline"><i class="fas fa-arrow-left"></i> 返回首页</a>
    </div>
    <div id="posts-loading" class="loading">加载中...</div>
    <div id="posts-error" class="error-msg"></div>
    <div id="posts-list"></div>
  </div>

  <div class="admin-view" id="view-edit">
    <div class="edit-box">
      <h3 id="edit-heading"><i class="fas fa-pen"></i> 编辑文章</h3>
      <form id="edit-form">
        <input type="hidden" id="edit-id">
        <div class="form-group">
          <label>标题</label>
          <input type="text" id="edit-title" required placeholder="文章标题">
        </div>
        <div class="form-group">
          <label>内容 (Markdown)</label>
          <textarea id="edit-content" required placeholder="支持 Markdown 语法"></textarea>
        </div>
        <div class="form-group">
          <label>标签（逗号分隔）</label>
          <input type="text" id="edit-tags" placeholder="标签1, 标签2">
        </div>
        <div class="form-group">
          <label>封面图 URL</label>
          <input type="text" id="edit-cover" placeholder="https://...">
        </div>
        <div class="error-msg" id="edit-error"></div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="edit-submit">保存</button>
          <button type="button" class="btn btn-outline" onclick="cancelEdit()">取消</button>
        </div>
      </form>
    </div>
  </div>

  <div class="admin-view" id="view-change-pw">
    <div class="edit-box">
      <h3><i class="fas fa-key"></i> 修改密码</h3>
      <form id="change-pw-form">
        <div class="form-group">
          <label>新密码</label>
          <input type="password" id="new-password" required placeholder="输入新密码" minlength="6">
        </div>
        <div class="form-group">
          <label>确认新密码</label>
          <input type="password" id="confirm-password" required placeholder="再次输入新密码" minlength="6">
        </div>
        <div id="change-pw-message" class="message-msg" style="display:none;"></div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="change-pw-submit">确认修改</button>
          <button type="button" class="btn btn-outline" onclick="cancelChangePw()">取消</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script type="module" src="<%= basePath %>/assets/admin.js" onerror="document.getElementById('view-login').innerHTML='<p style=color:red>admin.js 加载失败，请先运行 npx vite build</p>'"></script>
</body>
</html>