<%- include('partials/header', { title: locale.tags?.title || '标签', subtitle: (locale.tags?.subtitle_prefix || '共 ') + allTagCounts.length + ' ' + (locale.tags?.subtitle_suffix || '个标签') }) %>

  <main class="layout<%= !config.ASIDE_ENABLE ? ' hide-aside' : '' %>" id="content-inner">
    <div id="page">

      <% if (allTagCounts.length === 0) { %>
        <div class="empty-state reveal">
          <div class="empty-icon"><i class="fas fa-tags"></i></div>
          <h3><%= locale.tags?.empty_title || '暂无标签' %></h3>
        </div>
      <% } else { %>
        <div class="tag-cloud-list text-center">
          <% allTagCounts.forEach(t => { %>
            <% var tagEnc = encodeURIComponent(t.name) %>
            <% var hue = Math.floor(Math.random() * 360) %>
            <a href="<%= basePath %><%= isStatic ? '/tag/' + tagEnc + '/' : '/?tag=' + tagEnc %>" style="font-size:<%= Math.min(1.8, 0.8 + t.count * 0.15) %>em;color:hsl(<%= hue %>,55%,45%)">
              <%= t.name %>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="aside-content" id="aside-content">
      <%- include('partials/sidebar') %>
    </div>
  </main>

<%- include('partials/footer') %>