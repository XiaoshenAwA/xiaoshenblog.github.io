<%- include('partials/header', { title: post.title, top_img: (!config.DISABLE_TOP_IMG && post.cover) ? post.cover : config.DEFAULT_TOP_IMG || '', post: post }) %>

  <main class="layout<%= !config.ASIDE_ENABLE ? ' hide-aside' : '' %>" id="content-inner">
    <div id="post">
      <article class="post-article reveal">
        <div class="post-content"><%- post.contentHtml %></div>
        <div class="post-actions">
          <% if (!isStatic) { %>
          <div id="admin-actions" style="display:none">
            <a href="<%= basePath %>/posts/<%= post.id %>/edit" class="btn btn-primary"><i class="fas fa-edit"></i> <%= locale.post?.edit || '编辑' %></a>
            <a href="#" class="btn btn-danger" onclick="if(confirm('<%= locale.post?.delete_confirm || '确定删除？' %>')){var f=document.getElementById('df');f.action=this.getAttribute('data-action');f.submit()}return false" data-action="<%= basePath %>/posts/<%= post.id %>?_method=DELETE"><i class="fas fa-trash"></i> <%= locale.post?.delete || '删除' %></a>
            <form id="df" method="POST" style="display:none"></form>
          </div>
          <% } %>
        </div>

        <div class="post-nav">
          <% if (prevPost) { %>
          <a href="<%= basePath %>/posts/<%= prevPost.id %>/" class="post-nav-item post-nav-prev">
            <span class="post-nav-label"><i class="fas fa-arrow-left"></i> <%= locale.post?.prev_post || '上一篇' %></span>
            <span class="post-nav-title"><%= prevPost.title %></span>
          </a>
          <% } else { %>
          <div></div>
          <% } %>
          <% if (nextPost) { %>
          <a href="<%= basePath %>/posts/<%= nextPost.id %>/" class="post-nav-item post-nav-next">
            <span class="post-nav-label"><%= locale.post?.next_post || '下一篇' %> <i class="fas fa-arrow-right"></i></span>
            <span class="post-nav-title"><%= nextPost.title %></span>
          </a>
          <% } %>
        </div>

        <a href="<%= basePath %>/" class="btn btn-outline" style="margin-top:20px"><i class="fas fa-arrow-left"></i> <%= locale.post?.back_home || '返回首页' %></a>
        <script>
        try { if (sessionStorage.getItem('admin')) document.getElementById('admin-actions').style.display = ''; } catch(e){}
        </script>

        <% if (config.COMMENTS_USE === 'giscus' && config.GISCUS_REPO) { %>
        <div class="post-comments">
          <script src="<%= config.GISCUS_SCRIPT_URL %>"
            data-repo="<%= config.GISCUS_REPO %>"
            data-repo-id="<%= config.GISCUS_REPO_ID %>"
            data-category="<%= config.GISCUS_CATEGORY %>"
            data-category-id="<%= config.GISCUS_CATEGORY_ID %>"
            data-mapping="<%= config.GISCUS_MAPPING %>"
            data-strict="<%= config.GISCUS_STRICT %>"
            data-reactions-enabled="<%= config.GISCUS_REACTIONS_ENABLED %>"
            data-emit-metadata="<%= config.GISCUS_EMIT_METADATA %>"
            data-input-position="<%= config.GISCUS_INPUT_POSITION %>"
            data-theme="<%= config.GISCUS_LIGHT_THEME %>"
            data-lang="<%= config.GISCUS_LANG || config.SITE_LANGUAGE %>"
            crossorigin="anonymous"
            async>
          </script>
        </div>
        <% } %>
      </article>
    </div>

    <div class="aside-content" id="aside-content">
      <%- include('partials/sidebar') %>
      <% if (config.TOC_POST) { %>
      <div class="card-widget<%= config.TOC_STYLE_SIMPLE ? ' toc-simple' : '' %>" id="toc-widget" style="display:none">
        <div class="item-headline"><i class="fas fa-list"></i> <%= locale.post?.toc_title || '目录' %></div>
        <div class="toc-content" id="toc-content"></div>
      </div>
      <% } %>
    </div>
  </main>

  <script>
  try {
    var headings = document.querySelectorAll('.post-content h1, .post-content h2, .post-content h3');
    var toc = document.getElementById('toc-content');
    var tocWidget = document.getElementById('toc-widget');
    if (toc && headings.length > 0) {
      <%
        var tocExpandClass = '';
        if (config.TOC_EXPAND) tocExpandClass = ' toc-expand';
      %>
      toc.className += '<%= tocExpandClass %>';
      headings.forEach(function(h, i) {
        if (!h.id) h.id = 'heading-' + i;
        var a = document.createElement('a');
        a.href = '#' + h.id;
        <% if (config.TOC_NUMBER) { %>
        a.textContent = (i + 1) + '. ' + h.textContent;
        <% } else { %>
        a.textContent = h.textContent;
        <% } %>
        a.className = 'toc-link toc-link-' + h.tagName.toLowerCase();
        toc.appendChild(a);
      });
      tocWidget.style.display = '';
    }
  } catch(e) {}
  </script>

<%- include('partials/footer') %>